---
import { ensureTrailingSlash } from "@/lib/utils";

const navDropdowns = [
  {
    name: "Health Insurance",
    sections: [
      {
        title: "Get Started",
        items: [
          { name: "New to Switzerland", href: "/healthcare/new-health-insurance" },
          { name: "Switch Your Insurance", href: "/healthcare/switching-health-insurance" },
          { name: "Best Insurance 2026", href: "/healthcare/best-health-insurance-switzerland" },
          { name: "How Swiss Insurance Works", href: "/healthcare-system" },
        ],
      },
      {
        title: "By Location",
        items: [
          { name: "Zurich", href: "/health-insurance/zurich" },
          { name: "Geneva", href: "/health-insurance/geneva" },
          { name: "Basel", href: "/health-insurance/basel" },
          { name: "Zug", href: "/health-insurance/zug" },
          { name: "All Locations", href: "/health-insurance" },
        ],
      },
      {
        title: "Compare",
        items: [
          { name: "Helsana vs SWICA", href: "/compare-providers/helsana-vs-swica" },
          { name: "CSS vs Sanitas", href: "/compare-providers/css-vs-sanitas" },
          { name: "All Comparisons", href: "/compare-providers" },
          { name: "All Insurance Providers", href: "/insurance-providers" },
        ],
      },
      {
        title: "Guides",
        items: [
          { name: "How-To Guides", href: "/guides/how-to" },
          { name: "Blog & News", href: "/blog" },
          { name: "Insurance Glossary", href: "/healthcare/best-health-insurance-switzerland" },
          { name: "Premium Calculator (AI)", href: "/ai-chat" },
        ],
      },
    ],
    gridCols: "grid-cols-4",
    width: "w-[700px]",
  },
  {
    name: "Private & Supplementary",
    sections: [
      {
        title: "Coverage Types",
        items: [
          { name: "Semi-Private vs Private", href: "/blog/semi-private-vs-private-hospital-insurance" },
          { name: "Best Private Insurance 2026", href: "/blog/best-private-health-insurance-expats-switzerland" },
          { name: "Private Hospital Costs", href: "/blog/private-hospital-insurance-cost-switzerland-2026" },
          { name: "Mental Health Coverage", href: "/blog/mental-health-insurance-coverage-switzerland" },
        ],
      },
      {
        title: "By Insurer",
        items: [
          { name: "SWICA COMPLETA & Bestmed", href: "/blog/swica-completa-bestmed-review" },
          { name: "Helsana TOP & Primeo", href: "/blog/helsana-top-primeo-review" },
          { name: "Compare All Products", href: "/blog/private-hospital-insurance-cost-switzerland-2026" },
        ],
      },
      {
        title: "Other Insurance",
        items: [
          { name: "Household Insurance", href: "/insurance/household-insurance" },
          { name: "Personal Liability", href: "/insurance/personal-liability-insurance" },
          { name: "Legal Protection", href: "/insurance/legal-protection-insurance" },
          { name: "Life Insurance", href: "/life-insurance" },
          { name: "International Insurance", href: "/blog/international-health-insurance-switzerland" },
        ],
      },
    ],
    gridCols: "grid-cols-3",
    width: "w-[560px]",
  },
  {
    name: "3rd Pillar & Tax",
    sections: [
      {
        title: "Tax Optimization",
        items: [
          { name: "Tax Savings Guide", href: "/guides/how-to/save-taxes-with-3a-pillar" },
          { name: "Tax Savings 2026", href: "/blog/third-pillar-maximize-2026-tax-benefits" },
          { name: "Canton Tax Comparison", href: "/blog/swiss-cantonal-taxes-3rd-pillar-savings" },
          { name: "Self-Employed Guide", href: "/blog/3rd-pillar-self-employed-switzerland" },
        ],
      },
      {
        title: "Providers & Products",
        items: [
          { name: "Best 3a Providers 2026", href: "/blog/best-3rd-pillar-providers-switzerland" },
          { name: "VIAC vs Frankly vs finpension", href: "/blog/viac-vs-frankly-vs-finpension-comparison" },
          { name: "Bank vs Insurance 3a", href: "/3rd-pillar/bank-vs-insurance" },
          { name: "3a vs 3b Comparison", href: "/3rd-pillar/3a-vs-3b" },
        ],
      },
      {
        title: "Planning",
        items: [
          { name: "Leaving Switzerland Guide", href: "/blog/leaving-switzerland-pension-withdrawal-guide" },
          { name: "Withdrawal Guide", href: "/3rd-pillar/withdrawal-guide" },
          { name: "3rd Pillar Overview", href: "/3rd-pillar" },
          { name: "Pension Planning", href: "/pension-planning" },
        ],
      },
    ],
    gridCols: "grid-cols-3",
    width: "w-[560px]",
  },
];

const mobileNavSections = [
  {
    icon: `<svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>`,
    name: "Health Insurance",
    items: navDropdowns[0].sections.flatMap(s => s.items),
  },
  {
    icon: `<svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>`,
    name: "Private & Supplementary",
    items: navDropdowns[1].sections.flatMap(s => s.items),
  },
  {
    icon: `<svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    name: "3rd Pillar & Tax",
    items: navDropdowns[2].sections.flatMap(s => s.items),
  },
];
---

<header class="sticky top-0 bg-white shadow-sm z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20 gap-4">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href={ensureTrailingSlash("/")} class="flex items-center">
          <img
            src="https://res.cloudinary.com/dphbnwjtx/image/upload/v1740080077/logoexpatsavvy_sykutm.svg"
            alt="Expat Savvy"
            class="h-12"
            width="180"
            height="48"
          />
        </a>
      </div>

      <!-- Desktop Menu -->
      <div
        class="desktop-menu hidden md:flex md:items-center md:space-x-6 md:flex-1 md:justify-center"
      >
        <style>
          @media (min-width: 768px) {
            .desktop-menu {
              display: flex !important;
              align-items: center;
              gap: 1.5rem;
            }
          }
        </style>
        {
          navDropdowns.map((dropdown) => (
            <div class="relative group">
              <button class="text-gray-700 hover:text-red-600 flex items-center py-2 px-2 font-medium transition-colors">
                {dropdown.name}
                <svg
                  class="ml-1.5 h-4 w-4 transition-transform duration-200 group-hover:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </button>

              <div class={`absolute left-1/2 -translate-x-1/2 pt-2 ${dropdown.width} opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50`}>
                <div class="bg-white rounded-xl shadow-2xl p-6 border border-gray-100">
                  <div class={`grid ${dropdown.gridCols} gap-4`}>
                    {dropdown.sections.map((section) => (
                      <div>
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3 pb-2 border-b border-gray-100">
                          {section.title}
                        </h3>
                        <ul class="space-y-2">
                          {section.items.map((subItem) => (
                            <li>
                              <a
                                href={ensureTrailingSlash(subItem.href)}
                                class="group/item block text-sm text-gray-600 hover:text-red-600 transition-colors"
                              >
                                <span class="relative">
                                  {subItem.name}
                                  <span class="absolute bottom-0 left-0 w-full h-0.5 bg-red-600 transform scale-x-0 transition-transform duration-200 group-hover/item:scale-x-100" />
                                </span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Primary CTA Button (Right Side) -->
      <div class="hidden md:block flex-shrink-0">
        <button
          onclick="window.openContextualModal('header')"
          class="bg-red-600 hover:bg-red-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transition-all"
        >
          Book Free Consultation
        </button>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button
          id="mobile-menu-button"
          class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <svg
            class="block h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-50 md:hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <div
      class="absolute right-0 top-0 w-full max-w-sm h-full bg-white shadow-xl overflow-y-auto"
    >
      <div class="flex items-center justify-between p-4 border-b">
        <h2 class="text-lg font-semibold text-gray-900">Menu</h2>
        <button
          id="mobile-menu-close"
          class="p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <div class="px-2 py-3">
        <!-- Expandable Sections -->
        {
          mobileNavSections.map((section) => (
            <details class="group mb-2">
              <summary
                class="font-semibold text-gray-900 py-3 px-4 cursor-pointer list-none hover:bg-gray-50 rounded-lg flex items-center justify-between gap-3"
              >
                <span class="flex items-center gap-3">
                  <Fragment set:html={section.icon} />
                  {section.name}
                </span>
                <svg
                  class="h-5 w-5 transition-transform duration-200 group-open:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </summary>
              <div class="pl-4 space-y-1 mt-2">
                {section.items.map((item) => (
                  <a
                    href={ensureTrailingSlash(item.href)}
                    class="block text-gray-700 py-2 px-4 hover:bg-gray-50 rounded-lg text-sm"
                  >
                    {item.name}
                  </a>
                ))}
              </div>
            </details>
          ))
        }

        <div class="border-t border-gray-200 my-4"></div>

        <!-- Quick Links -->
        <a
          href={ensureTrailingSlash("/about")}
          class="block text-gray-700 py-2 px-4 hover:bg-gray-50 rounded-lg"
        >
          About Us
        </a>

        <a
          href={ensureTrailingSlash("/ai-chat")}
          class="block text-gray-700 py-2 px-4 hover:bg-gray-50 rounded-lg"
        >
          Premium Calculator (AI)
        </a>

        <a
          href={ensureTrailingSlash("/blog")}
          class="block text-gray-700 py-2 px-4 hover:bg-gray-50 rounded-lg"
        >
          Blog
        </a>

        <!-- Mobile CTA -->
        <div class="pt-4 px-3">
          <button
            onclick="window.openContextualModal('header')"
            class="block w-full text-center bg-red-600 text-white px-4 py-4 rounded-xl hover:bg-red-700 transition-colors font-bold shadow-lg"
          >
            Book Free Consultation
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenuClose = document.getElementById("mobile-menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const body = document.body;

    // Mobile menu toggle
    function openMenu() {
      if (mobileMenu) {
        mobileMenu.classList.remove("hidden");
        body.style.overflow = "hidden";
      }
    }

    function closeMenu() {
      if (mobileMenu) {
        mobileMenu.classList.add("hidden");
        body.style.overflow = "";
      }
    }

    if (mobileMenuButton) {
      mobileMenuButton.addEventListener("click", openMenu);
    }

    if (mobileMenuClose) {
      mobileMenuClose.addEventListener("click", closeMenu);
    }

    // Close menu when clicking outside
    if (mobileMenu) {
      mobileMenu.addEventListener("click", (e) => {
        if (e.target === mobileMenu) {
          closeMenu();
        }
      });
    }

    // Close menu on escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closeMenu();
      }
    });
  });
</script>
