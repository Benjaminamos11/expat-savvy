---
// BlogPostSchema component for proper structured data on blog posts
interface Props {
  title: string;
  description: string;
  image: string;
  author?: string | { name: string };
  publishDate?: string;
  modifiedDate?: string;
  url?: string;
  faqs?: Array<{
    question: string;
    answer: string;
  }>;
}

const { 
  title, 
  description, 
  image, 
  author = "Benjamin Amos Wagner",
  publishDate, 
  modifiedDate = publishDate,
  url = Astro.url.href,
  faqs = []
} = Astro.props;

// Extract author name correctly
const authorName = typeof author === 'object' && author !== null ? author.name || "Benjamin Amos Wagner" : author;

// Build the BlogPosting schema
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": url
  },
  "headline": title,
  "description": description,
  "image": image,
  "author": {
    "@type": "Person",
    "name": authorName,
    "url": "https://benjaminwagner.ch",
    "jobTitle": "Founder & Insurance Advisor",
    "worksFor": {
      "@type": "Organization",
      "name": "Expat Savvy Switzerland",
      "url": "https://expat-savvy.ch"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Expat Savvy",
    "logo": {
      "@type": "ImageObject",
      "url": "https://res.cloudinary.com/dphbnwjtx/image/upload/v1740080077/logoexpatsavvy_sykutm.svg",
      "width": 600,
      "height": 60
    }
  },
  "datePublished": publishDate,
  "dateModified": modifiedDate
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema, null, 2)}></script> 