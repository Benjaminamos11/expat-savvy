---
// GermanConsultationModal.astro — Calendar-First 3-Step Flow (DE)
// Step 1: Topic + Timeline → Step 2: Pick date & time (Cal.com v2 API) → Step 3: Form + Confirm booking
---

<!-- React Modal Container -->
<div id="german-modal-root"></div>

<!-- React loaded globally in BaseLayout -->
<script is:inline>
    // Immediately define placeholder functions to prevent errors
    if (typeof window !== "undefined") {
        window.openGermanModal = function () {
            console.warn("⏳ German Modal still loading...");
        };
    }

    // Wait for React to load
    function waitForReact(callback) {
        if (typeof React !== "undefined" && typeof ReactDOM !== "undefined") {
            callback();
        } else {
            setTimeout(() => waitForReact(callback), 100);
        }
    }

    waitForReact(() => {
        const { useState, useEffect, useCallback, useRef, createElement: h } = React;

        const CAL_API_BASE = "https://api.cal.com/v2";

        // ── Checkbox item component ──
        const CheckboxCard = ({ label, value, checked, onChange }) => {
            return h(
                "label",
                {
                    className:
                        "flex items-center gap-3 p-3 md:p-4 rounded-xl border-2 cursor-pointer transition-all " +
                        (checked
                            ? "border-red-500 bg-red-50 shadow-sm"
                            : "border-gray-200 bg-white hover:border-gray-300 hover:bg-gray-50"),
                },
                h("input", {
                    type: "checkbox",
                    checked: checked,
                    onChange: () => onChange(value),
                    className: "sr-only",
                }),
                h(
                    "span",
                    {
                        className:
                            "w-5 h-5 flex-shrink-0 rounded border-2 flex items-center justify-center transition-colors " +
                            (checked
                                ? "bg-red-600 border-red-600"
                                : "border-gray-300 bg-white"),
                    },
                    checked &&
                        h(
                            "svg",
                            {
                                className: "w-3.5 h-3.5 text-white",
                                fill: "none",
                                stroke: "currentColor",
                                viewBox: "0 0 24 24",
                            },
                            h("path", {
                                strokeLinecap: "round",
                                strokeLinejoin: "round",
                                strokeWidth: "3",
                                d: "M5 13l4 4L19 7",
                            }),
                        ),
                ),
                h(
                    "span",
                    {
                        className:
                            "text-sm font-medium " +
                            (checked ? "text-gray-900" : "text-gray-700"),
                    },
                    label,
                ),
            );
        };

        // ── Timeline Pill component ──
        const TimelinePill = ({ label, value, selected, onSelect }) => {
            return h(
                "button",
                {
                    type: "button",
                    onClick: () => onSelect(value),
                    className:
                        "px-4 py-2.5 rounded-full text-sm font-medium transition-all border " +
                        (selected
                            ? "bg-slate-900 text-white border-slate-900 shadow-md"
                            : "bg-white text-gray-600 border-gray-200 hover:border-gray-400 hover:bg-gray-50"),
                },
                label,
            );
        };

        // ── Main Modal Component ──
        const GermanConsultationModal = ({ isOpen, onClose, initialTopic }) => {
            const [step, setStep] = useState(1);
            const [topics, setTopics] = useState([]);
            const [timeline, setTimeline] = useState("");
            const [selectedDate, setSelectedDate] = useState(null);
            const [selectedSlot, setSelectedSlot] = useState(null);
            const [slots, setSlots] = useState([]);
            const [slotsLoading, setSlotsLoading] = useState(false);
            const [messageMode, setMessageMode] = useState(false);
            const [formData, setFormData] = useState({
                name: "",
                email: "",
                phone: "",
                notes: "",
                message: "",
            });
            const [booking, setBooking] = useState(false);
            const [bookingError, setBookingError] = useState("");
            const [bookingDone, setBookingDone] = useState(false);
            const [bookingDetails, setBookingDetails] = useState("");
            const slotsCache = useRef({});
            const abortRef = useRef(null);

            const experts = {
                robert: {
                    id: "robert",
                    name: "Robert Kolar",
                    title: "Senior Health Insurance Expert",
                    subtitle: "Spezialist für Zuwanderer · DE/EN",
                    valueProp:
                        "Gesundheits-Setup. Sichern Sie sich Ihren Premium-Standard in der Schweiz. Kostenlos und unverbindlich.",
                    badges: [
                        "Langjährige Branchenerfahrung",
                        "Unabhängige Beratung. Alle Krankenkassen der Schweiz.",
                        "100% Digital & Transparent",
                    ],
                    image: "https://res.cloudinary.com/dphbnwjtx/image/upload/w_250,h_250,q_95,f_webp,c_fill,g_face,e_sharpen:100/v1757251477/Generated_Image_September_07_2025_-_9_20PM_uuse1r.webp",
                    eventTypeId: 1894802,
                    apiKey: "cal_live_02d332e8841c6f13b371ee6dd3ca7ca8",
                },
                hans: {
                    id: "hans",
                    name: "Hans Steiner",
                    title: "dipl. Finanzplaner IAF",
                    subtitle: "Spezialist für Zuwanderer · DE/EN/FR",
                    valueProp:
                        "Exklusive Finanzplanung. Massgeschneiderte Strategien für Steuern und Vorsorge. Kostenlos und unverbindlich.",
                    badges: [
                        "FINMA-registriert",
                        "1000+ betreute Zuwanderer",
                        "Schweizer Datenschutz",
                    ],
                    image: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_auto,q_auto,w_250,h_250,c_fill,g_face/v1772294525/WhatsApp_Image_2026-02-28_at_10.33.38_pd2of6.jpg",
                    eventTypeId: 4550098,
                    apiKey: "cal_live_8cb1d91e956c64fd591ca700ff9bc523",
                },
            };

            const activeExpert = topics.includes("wealth")
                ? experts.hans
                : experts.robert;

            const detectedTZ = (typeof Intl !== "undefined" && Intl.DateTimeFormat().resolvedOptions().timeZone) || "Europe/Zurich";
            const [timeZone, setTimeZone] = useState(detectedTZ);
            const [tzOpen, setTzOpen] = useState(false);

            const commonTZList = ['Europe/Zurich','Europe/Berlin','Europe/Vienna','Europe/London','Europe/Paris','Europe/Amsterdam','Europe/Rome','Europe/Madrid','Europe/Stockholm','Europe/Warsaw','America/New_York','America/Chicago','America/Denver','America/Los_Angeles','America/Toronto','Asia/Dubai','Asia/Singapore','Asia/Tokyo','Asia/Hong_Kong','Australia/Sydney','Pacific/Auckland'];
            const shortTZName = (tz) => tz.replace(/_/g,' ').split('/').pop();

            const toggleTopic = useCallback((val) => {
                setTopics((prev) =>
                    prev.includes(val)
                        ? prev.filter((t) => t !== val)
                        : [...prev, val],
                );
            }, []);

            const handleInputChange = (e) =>
                setFormData((prev) => ({
                    ...prev,
                    [e.target.name]: e.target.value,
                }));

            // Generate business days
            const businessDays = [];
            const today = new Date();
            for (let i = 0; businessDays.length < 7; i++) {
                const d = new Date(today);
                d.setDate(today.getDate() + i);
                if (d.getDay() !== 0) businessDays.push(d);
            }

            // Fetch slots for a date
            const fetchSlots = useCallback(async (dateStr) => {
                const cacheKey = activeExpert.eventTypeId + "-" + dateStr + "-" + timeZone;
                if (slotsCache.current[cacheKey] && Date.now() - slotsCache.current[cacheKey].ts < 60000) {
                    setSlots(slotsCache.current[cacheKey].data);
                    setSlotsLoading(false);
                    return;
                }

                setSlotsLoading(true);
                setSlots([]);

                if (abortRef.current) abortRef.current.abort();
                abortRef.current = new AbortController();

                try {
                    const params = new URLSearchParams({
                        eventTypeId: activeExpert.eventTypeId.toString(),
                        startTime: dateStr + "T00:00:00Z",
                        endTime: dateStr + "T23:59:59Z",
                        timeZone: timeZone,
                    });
                    const res = await fetch(CAL_API_BASE + "/slots/available?" + params.toString(), {
                        headers: {
                            "Authorization": "Bearer " + activeExpert.apiKey,
                            "cal-api-version": "2024-08-13",
                        },
                        signal: abortRef.current.signal,
                    });
                    const json = await res.json();
                    const slotsData = (json.data && json.data.slots && json.data.slots[dateStr]) || [];
                    slotsCache.current[cacheKey] = { data: slotsData, ts: Date.now() };
                    setSlots(slotsData);
                } catch (err) {
                    if (err.name !== "AbortError") setSlots([]);
                } finally {
                    setSlotsLoading(false);
                }
            }, [activeExpert.eventTypeId, activeExpert.apiKey, timeZone]);

            // Reset on open/close
            useEffect(() => {
                if (isOpen) {
                    setStep(1);
                    setTopics(
                        initialTopic && initialTopic !== "health"
                            ? [initialTopic]
                            : [],
                    );
                    setTimeline("");
                    setSelectedDate(null);
                    setSelectedSlot(null);
                    setSlots([]);
                    setMessageMode(false);
                    setFormData({ name: "", email: "", phone: "", notes: "", message: "" });
                    setBooking(false);
                    setBookingError("");
                    setBookingDone(false);
                    setBookingDetails("");
                    slotsCache.current = {};
                    document.body.style.overflow = "hidden";
                } else {
                    document.body.style.overflow = "";
                }
                return () => { document.body.style.overflow = ""; };
            }, [isOpen, initialTopic]);

            // Escape key
            useEffect(() => {
                const handleKeyDown = (e) => {
                    if (e.key === "Escape" && isOpen) onClose();
                };
                if (isOpen) document.addEventListener("keydown", handleKeyDown);
                return () => document.removeEventListener("keydown", handleKeyDown);
            }, [isOpen, onClose]);

            if (!isOpen) return null;

            // ── Step indicator dots ──
            const stepDots = h(
                "div",
                { className: "flex items-center justify-center gap-2 mb-6" },
                [1, 2, 3].map((s) =>
                    h("div", {
                        key: s,
                        className:
                            "h-1.5 rounded-full transition-all " +
                            (s === step
                                ? "w-8 bg-red-500"
                                : s < step
                                  ? "w-4 bg-red-300"
                                  : "w-4 bg-gray-200"),
                    }),
                ),
            );

            // ── Checkmark SVG for badges ──
            const checkSvg = () =>
                h(
                    "svg",
                    {
                        className: "w-5 h-5 text-green-400 mr-3 flex-shrink-0",
                        fill: "none",
                        stroke: "currentColor",
                        viewBox: "0 0 24 24",
                    },
                    h("path", {
                        strokeLinecap: "round",
                        strokeLinejoin: "round",
                        strokeWidth: "2",
                        d: "M5 13l4 4L19 7",
                    }),
                );

            // ── LEFT SIDEBAR ──
            const leftSidebar = h(
                "div",
                {
                    className:
                        "hidden md:flex w-full md:w-5/12 bg-slate-900 text-white p-8 lg:p-10 flex-col relative overflow-y-auto",
                },
                h("div", {
                    className:
                        "absolute inset-0 bg-gradient-to-b from-slate-800/50 to-slate-900/90 pointer-events-none",
                }),
                h(
                    "div",
                    { className: "relative z-10 flex-1 flex flex-col" },
                    h(
                        "span",
                        {
                            className:
                                "text-red-500 font-semibold text-xs tracking-widest uppercase mb-8 block",
                        },
                        "Ihr Berater",
                    ),
                    h(
                        "div",
                        { className: "relative w-32 h-32 mb-6 shadow-xl" },
                        h("img", {
                            src: activeExpert.image,
                            alt: activeExpert.name,
                            className:
                                "w-full h-full object-cover rounded-2xl border-2 border-slate-700 bg-slate-800",
                        }),
                    ),
                    h(
                        "h3",
                        { className: "text-3xl font-extrabold mb-1" },
                        activeExpert.name,
                    ),
                    h(
                        "p",
                        { className: "text-red-400 font-bold mb-1" },
                        activeExpert.title,
                    ),
                    h(
                        "p",
                        {
                            className:
                                "text-slate-400 text-sm mb-6 pb-6 border-b border-slate-700",
                        },
                        activeExpert.subtitle,
                    ),
                    h(
                        "p",
                        {
                            className:
                                "text-lg text-slate-300 leading-relaxed font-light mb-8",
                        },
                        '"' + activeExpert.valueProp + '"',
                    ),
                    h(
                        "div",
                        { className: "mt-auto" },
                        h(
                            "ul",
                            { className: "space-y-3" },
                            activeExpert.badges.map((badge, idx) =>
                                h(
                                    "li",
                                    {
                                        key: idx,
                                        className:
                                            "flex items-center text-sm text-slate-300",
                                    },
                                    checkSvg(),
                                    badge,
                                ),
                            ),
                        ),
                    ),
                ),
            );

            // ── STEP 1: Bedarf & Zeitplan ──
            const step1Content = h(
                "div",
                {
                    className:
                        "md:max-w-md mx-auto h-full flex flex-col md:justify-center modal-fadeIn py-1 md:py-2",
                },
                stepDots,
                h(
                    "div",
                    { className: "mb-4 md:mb-6 text-center md:text-left" },
                    h(
                        "h2",
                        {
                            className:
                                "text-2xl md:text-3xl font-extrabold text-gray-900 mb-1",
                        },
                        "Welche Themen möchten Sie besprechen?",
                    ),
                    h(
                        "p",
                        { className: "text-gray-500 text-sm" },
                        "Ihre persönliche Strategie-Session. Kostenlos & unverbindlich.",
                    ),
                ),

                // Topic checkboxes
                h(
                    "div",
                    { className: "space-y-2 md:space-y-3 mb-4 md:mb-6" },
                    h(CheckboxCard, {
                        label: "Krankenversicherung & Gesundheits-Setup",
                        value: "health",
                        checked: topics.includes("health"),
                        onChange: toggleTopic,
                    }),
                    h(CheckboxCard, {
                        label: "Steueroptimierung & Säule 3a",
                        value: "wealth",
                        checked: topics.includes("wealth"),
                        onChange: toggleTopic,
                    }),
                    h(CheckboxCard, {
                        label: "Haftpflicht & Hausrat",
                        value: "everyday",
                        checked: topics.includes("everyday"),
                        onChange: toggleTopic,
                    }),
                    h(CheckboxCard, {
                        label: "Familienplanung & Schwangerschaft",
                        value: "family",
                        checked: topics.includes("family"),
                        onChange: toggleTopic,
                    }),
                ),

                // Timeline
                h(
                    "div",
                    { className: "mb-4 md:mb-6" },
                    h(
                        "label",
                        {
                            className:
                                "block text-sm font-semibold text-gray-700 mb-3",
                        },
                        "Ihr aktueller Status",
                    ),
                    h(
                        "div",
                        { className: "flex flex-wrap gap-2" },
                        h(TimelinePill, {
                            label: "Noch nicht umgezogen",
                            value: "pre-move",
                            selected: timeline === "pre-move",
                            onSelect: setTimeline,
                        }),
                        h(TimelinePill, {
                            label: "< 3 Monate in CH",
                            value: "under-3m",
                            selected: timeline === "under-3m",
                            onSelect: setTimeline,
                        }),
                        h(TimelinePill, {
                            label: "> 3 Monate in CH",
                            value: "over-3m",
                            selected: timeline === "over-3m",
                            onSelect: setTimeline,
                        }),
                    ),
                ),

                // WEITER button
                h(
                    "button",
                    {
                        type: "button",
                        disabled: topics.length === 0,
                        onClick: () => setStep(2),
                        className:
                            "w-full flex items-center justify-center py-4 px-8 rounded-2xl shadow-lg text-lg font-bold text-white transition-all transform " +
                            (topics.length > 0
                                ? "bg-red-600 hover:bg-red-700 shadow-red-500/30 hover:-translate-y-0.5 cursor-pointer"
                                : "bg-gray-300 cursor-not-allowed"),
                    },
                    "WEITER",
                    h(
                        "svg",
                        {
                            className: "ml-2 w-5 h-5",
                            fill: "none",
                            stroke: "currentColor",
                            viewBox: "0 0 24 24",
                        },
                        h("path", {
                            strokeLinecap: "round",
                            strokeLinejoin: "round",
                            strokeWidth: "2",
                            d: "M14 5l7 7m0 0l-7 7m7-7H3",
                        }),
                    ),
                ),
            );

            // ── STEP 2: Calendar (Date pills + Time slots via API) ──
            const step2Content = h(
                "div",
                {
                    className:
                        "md:max-w-md mx-auto h-full flex flex-col md:justify-center modal-fadeIn py-1 md:py-2",
                },
                stepDots,
                h(
                    "div",
                    { className: "mb-4 md:mb-6" },
                    h(
                        "button",
                        {
                            type: "button",
                            onClick: () => { setStep(1); setSelectedDate(null); setSelectedSlot(null); setSlots([]); },
                            className:
                                "inline-flex items-center text-sm font-semibold text-gray-500 hover:text-gray-900 transition-colors mb-4",
                        },
                        "← Zurück",
                    ),
                    h(
                        "h2",
                        {
                            className:
                                "text-2xl md:text-3xl font-extrabold text-gray-900 mb-1",
                        },
                        "Wählen Sie einen Termin",
                    ),
                    h(
                        "p",
                        { className: "text-gray-500 text-sm" },
                        "Kostenlos, online, unverbindlich · bis zu 60 Min",
                    ),
                ),

                // Date pills
                h(
                    "div",
                    { className: "mb-4" },
                    h("div", { className: "flex items-center justify-between mb-2" },
                        h("label", { className: "text-[10px] font-bold text-slate-400 uppercase tracking-widest" }, "Datum wählen"),
                        h("div", { className: "flex items-center gap-1" },
                            h("svg", { className: "w-3 h-3 text-gray-300", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
                                h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" })
                            ),
                            !tzOpen
                                ? h("span", {
                                    className: "text-[10px] text-red-600 font-medium cursor-pointer hover:text-red-800 transition-colors",
                                    onClick: () => setTzOpen(true)
                                  }, shortTZName(timeZone) + " ▾")
                                : h("select", {
                                    className: "text-[10px] text-gray-500 bg-white border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:border-red-400",
                                    value: timeZone,
                                    autoFocus: true,
                                    onChange: (e) => {
                                        setTimeZone(e.target.value);
                                        slotsCache.current = {};
                                        setTzOpen(false);
                                        if (selectedDate) fetchSlots(selectedDate);
                                    },
                                    onBlur: () => setTzOpen(false)
                                  }, (commonTZList.indexOf(timeZone) === -1 ? [timeZone] : []).concat(commonTZList).map(tz =>
                                    h("option", { key: tz, value: tz }, tz.replace(/_/g, " "))
                                  ))
                        )
                    ),
                    h(
                        "div",
                        { className: "flex gap-2 overflow-x-auto pb-1", style: { scrollbarWidth: "none" } },
                        businessDays.map((date) => {
                            const iso = date.toISOString().split("T")[0];
                            const dayName = date.toLocaleDateString("de", { weekday: "short" });
                            const dayNum = date.getDate();
                            const monthName = date.toLocaleDateString("de", { month: "short" });
                            const isSelected = selectedDate === iso;
                            return h(
                                "button",
                                {
                                    key: iso,
                                    type: "button",
                                    onClick: () => {
                                        setSelectedDate(iso);
                                        setSelectedSlot(null);
                                        fetchSlots(iso);
                                    },
                                    className:
                                        "flex-shrink-0 px-3 py-2 text-center rounded-xl border-2 cursor-pointer transition-all " +
                                        (isSelected
                                            ? "border-red-500 bg-red-50"
                                            : "border-slate-100 bg-white hover:border-slate-300"),
                                },
                                h("div", { className: "text-[9px] uppercase text-slate-400 leading-none" }, dayName),
                                h("div", { className: "text-base font-extrabold text-slate-900 leading-tight" }, dayNum),
                                h("div", { className: "text-[9px] text-slate-400 leading-none" }, monthName),
                            );
                        }),
                    ),
                ),

                // Time slots
                selectedDate && h(
                    "div",
                    { className: "mb-4" },
                    h(
                        "label",
                        { className: "block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2" },
                        "Verfügbare Zeiten",
                    ),
                    slotsLoading && h(
                        "div",
                        { className: "flex items-center justify-center py-4" },
                        h("div", { className: "w-4 h-4 border-2 border-red-200 border-t-red-600 rounded-full animate-spin mr-2" }),
                        h("span", { className: "text-xs text-slate-500" }, "Laden..."),
                    ),
                    !slotsLoading && slots.length === 0 && h(
                        "p",
                        { className: "text-xs text-slate-400 text-center py-4 italic" },
                        "Keine Verfügbarkeit — versuchen Sie einen anderen Tag",
                    ),
                    !slotsLoading && slots.length > 0 && h(
                        "div",
                        { className: "grid grid-cols-4 gap-2" },
                        slots.map((slot) => {
                            const time = new Date(slot.time);
                            const display = time.toLocaleTimeString("de", {
                                hour: "2-digit", minute: "2-digit", hour12: false, timeZone: timeZone,
                            });
                            const isActive = selectedSlot === slot.time;
                            return h(
                                "button",
                                {
                                    key: slot.time,
                                    type: "button",
                                    onClick: () => {
                                        setSelectedSlot(slot.time);
                                        setStep(3);
                                    },
                                    className:
                                        "px-2 py-2 rounded-xl border-2 text-xs font-bold transition-all " +
                                        (isActive
                                            ? "border-red-500 bg-red-50 text-red-600"
                                            : "border-slate-100 text-slate-700 bg-white hover:border-red-300 hover:text-red-600"),
                                },
                                display,
                            );
                        }),
                    ),
                ),

                // Escape link to message-only
                h(
                    "div",
                    { className: "text-center mt-2" },
                    h(
                        "button",
                        {
                            type: "button",
                            onClick: () => { setMessageMode(true); setStep(3); },
                            className: "text-[11px] text-gray-400 hover:text-gray-600 underline transition-colors",
                        },
                        "Nicht bereit zu buchen? Einfach eine Nachricht senden",
                    ),
                ),
            );

            // ── STEP 3: Form + Confirm ──
            const selectedTimeDisplay = selectedSlot
                ? (() => {
                    const d = new Date(selectedDate + "T12:00:00");
                    const dateStr = d.toLocaleDateString("de", { weekday: "short", month: "short", day: "numeric" });
                    const timeStr = new Date(selectedSlot).toLocaleTimeString("de", {
                        hour: "2-digit", minute: "2-digit", hour12: false, timeZone: timeZone,
                    });
                    return dateStr + " um " + timeStr;
                })()
                : "";

            const handleSubmit = async () => {
                if (!formData.name || !formData.email) {
                    setBookingError("Name und E-Mail erforderlich.");
                    return;
                }

                setBooking(true);
                setBookingError("");

                if (messageMode) {
                    // Message-only: save to messages table
                    fetch("/api/message", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            name: formData.name,
                            email: formData.email,
                            phone: formData.phone,
                            message: formData.message,
                            source: window.location.href,
                            language: "de",
                            device: window.innerWidth <= 768 ? "mobile" : "desktop",
                        }),
                    }).catch(() => {});
                    setBookingDone(true);
                    setBookingDetails("Wir melden uns in Kürze bei Ihnen.");
                    setBooking(false);
                    if (typeof window.fireFormSubmitConversion === 'function') window.fireFormSubmitConversion('consultation_message_de');
                    return;
                }

                // Lead capture for bookings (fire and forget)
                fetch("/api/lead", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        name: formData.name,
                        email: formData.email,
                        phone: formData.phone,
                        message: formData.notes,
                        flow: "german_modal_booking",
                        url: window.location.href,
                        device: window.innerWidth <= 768 ? "mobile" : "desktop",
                        notes: { booked_slot: selectedSlot, booked_date: selectedDate, timeline: timeline },
                    }),
                }).catch(() => {});

                // Book via Cal.com v2
                try {
                    const payload = {
                        eventTypeId: activeExpert.eventTypeId,
                        start: selectedSlot,
                        attendee: {
                            name: formData.name,
                            email: formData.email,
                            timeZone: timeZone,
                            language: "de",
                        },
                    };
                    if (formData.phone || formData.notes) {
                        payload.metadata = {};
                        if (formData.phone) payload.metadata.phone = formData.phone;
                        if (formData.notes) payload.metadata.notes = formData.notes;
                    }

                    const res = await fetch(CAL_API_BASE + "/bookings", {
                        method: "POST",
                        headers: {
                            "Authorization": "Bearer " + activeExpert.apiKey,
                            "Content-Type": "application/json",
                            "cal-api-version": "2024-08-13",
                        },
                        body: JSON.stringify(payload),
                    });

                    if (!res.ok) {
                        const err = await res.json().catch(() => ({}));
                        throw new Error(err.message || "Buchung fehlgeschlagen");
                    }

                    setBookingDone(true);
                    setBookingDetails(selectedTimeDisplay);
                    if (typeof window.fireBookingConversion === 'function') window.fireBookingConversion('german_consultation_modal');
                    if (typeof window.fireFormSubmitConversion === 'function') window.fireFormSubmitConversion('consultation_booking_de');
                } catch (err) {
                    setBookingError(err.message || "Buchung fehlgeschlagen. Bitte versuchen Sie es erneut.");
                } finally {
                    setBooking(false);
                }
            };

            const step3Content = bookingDone
                ? h(
                    "div",
                    { className: "md:max-w-md mx-auto h-full flex flex-col items-center justify-center modal-fadeIn py-8 text-center" },
                    h(
                        "div",
                        { className: "w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4" },
                        h(
                            "svg",
                            { className: "w-8 h-8 text-green-500", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
                            h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M5 13l4 4L19 7" }),
                        ),
                    ),
                    h("h2", { className: "text-2xl font-extrabold text-gray-900 mb-2" },
                        messageMode ? "Nachricht gesendet!" : "Buchung bestätigt!"),
                    h("p", { className: "text-gray-500 text-sm mb-6" }, bookingDetails),
                    !messageMode && h("p", { className: "text-gray-400 text-xs" }, "Prüfen Sie Ihre E-Mail für die Bestätigungsdetails."),
                    h(
                        "button",
                        {
                            type: "button",
                            onClick: onClose,
                            className: "mt-6 px-8 py-3 bg-gray-100 hover:bg-gray-200 rounded-xl font-bold text-gray-700 transition-all",
                        },
                        "Schliessen",
                    ),
                )
                : h(
                    "div",
                    {
                        className:
                            "md:max-w-md mx-auto h-full flex flex-col md:justify-center modal-fadeIn py-1 md:py-2",
                    },
                    stepDots,
                    h(
                        "div",
                        { className: "mb-4 md:mb-6" },
                        h(
                            "button",
                            {
                                type: "button",
                                onClick: () => {
                                    if (messageMode) { setMessageMode(false); setStep(2); }
                                    else { setStep(2); }
                                },
                                className:
                                    "inline-flex items-center text-sm font-semibold text-gray-500 hover:text-gray-900 transition-colors mb-4",
                            },
                            "← Zurück",
                        ),
                        h(
                            "h2",
                            {
                                className:
                                    "text-2xl md:text-3xl font-extrabold text-gray-900 mb-1",
                            },
                            messageMode ? "Nachricht senden" : "Ihre Kontaktdaten",
                        ),
                        h(
                            "p",
                            { className: "text-gray-500 text-sm" },
                            messageMode
                                ? "Wir melden uns so schnell wie möglich bei Ihnen"
                                : "Damit wir Ihren Termin bestätigen können",
                        ),
                    ),

                    // Selected slot display (if booking mode)
                    !messageMode && selectedTimeDisplay && h(
                        "div",
                        { className: "flex items-center gap-2 px-4 py-3 bg-red-50 border border-red-100 rounded-xl mb-4" },
                        h(
                            "svg",
                            { className: "w-5 h-5 text-red-500 flex-shrink-0", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
                            h("path", {
                                strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2",
                                d: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
                            }),
                        ),
                        h("span", { className: "text-sm font-bold text-red-600" }, selectedTimeDisplay),
                    ),

                    // Form fields
                    h(
                        "div",
                        { className: "space-y-3 md:space-y-4 mb-4 md:mb-5" },
                        h(
                            "div",
                            {},
                            h("label", { htmlFor: "de-name", className: "block text-sm font-semibold text-gray-700 mb-1.5" }, "Vollständiger Name"),
                            h("input", {
                                type: "text", id: "de-name", name: "name",
                                placeholder: "z.B. Max Mustermann",
                                value: formData.name, onChange: handleInputChange, required: true,
                                className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors",
                            }),
                        ),
                        h(
                            "div",
                            {},
                            h("label", { htmlFor: "de-email", className: "block text-sm font-semibold text-gray-700 mb-1.5" }, "E-Mail Adresse"),
                            h("input", {
                                type: "email", id: "de-email", name: "email",
                                placeholder: "max@firma.de",
                                value: formData.email, onChange: handleInputChange, required: true,
                                className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors",
                            }),
                        ),
                        h(
                            "div",
                            {},
                            h("label", { htmlFor: "de-phone", className: "block text-sm font-semibold text-gray-700 mb-1.5" }, "Telefonnummer (optional)"),
                            h("input", {
                                type: "tel", id: "de-phone", name: "phone",
                                placeholder: "+41 79 000 00 00",
                                value: formData.phone, onChange: handleInputChange,
                                className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors",
                            }),
                        ),
                        messageMode
                            ? h(
                                "div",
                                {},
                                h("label", { htmlFor: "de-message", className: "block text-sm font-semibold text-gray-700 mb-1.5" }, "Ihre Nachricht *"),
                                h("textarea", {
                                    id: "de-message", name: "message", rows: 3, required: true,
                                    placeholder: "Wie können wir Ihnen helfen?",
                                    value: formData.message, onChange: handleInputChange,
                                    className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors resize-none",
                                }),
                            )
                            : h(
                                "div",
                                {},
                                h("textarea", {
                                    id: "de-notes", name: "notes", rows: 2,
                                    placeholder: "Möchten Sie uns etwas mitteilen? (optional)",
                                    value: formData.notes, onChange: handleInputChange,
                                    className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors resize-none",
                                }),
                            ),
                    ),

                    // Error display
                    bookingError && h(
                        "div",
                        { className: "p-3 mb-4 rounded-xl bg-red-50 border border-red-200 text-red-600 text-sm text-center" },
                        bookingError,
                    ),

                    // Submit button
                    h(
                        "button",
                        {
                            type: "button",
                            disabled: booking || !formData.name || !formData.email || (messageMode && !formData.message),
                            onClick: handleSubmit,
                            className:
                                "w-full flex items-center justify-center py-4 px-8 rounded-2xl shadow-lg text-lg font-bold text-white transition-all transform " +
                                (booking || !formData.name || !formData.email || (messageMode && !formData.message)
                                    ? "bg-gray-300 cursor-not-allowed"
                                    : "bg-red-600 hover:bg-red-700 shadow-red-500/30 hover:-translate-y-0.5 cursor-pointer"),
                        },
                        booking
                            ? h(
                                "span",
                                { className: "flex items-center gap-2" },
                                h("svg", {
                                    className: "animate-spin h-5 w-5 text-white",
                                    fill: "none", viewBox: "0 0 24 24",
                                },
                                    h("circle", { className: "opacity-25", cx: "12", cy: "12", r: "10", stroke: "currentColor", strokeWidth: "4" }),
                                    h("path", { className: "opacity-75", fill: "currentColor", d: "M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" }),
                                ),
                                "Wird gebucht...",
                            )
                            : messageMode ? "NACHRICHT SENDEN" : "BUCHUNG BESTÄTIGEN",
                    ),
                    h(
                        "p",
                        { className: "text-center text-sm text-gray-500 mt-3" },
                        "Keine Kreditkarte erforderlich",
                    ),
                );

            // ── RENDER ──
            return h(
                "div",
                {
                    className:
                        "fixed inset-0 z-50 flex items-end md:items-center justify-center p-0 md:p-6",
                },
                // Backdrop
                h("div", {
                    className:
                        "absolute inset-0 bg-gray-900/80 backdrop-blur-sm transition-opacity",
                    onClick: onClose,
                }),

                // Modal Container
                h(
                    "div",
                    {
                        className:
                            "relative bg-white rounded-t-3xl md:rounded-[2.5rem] shadow-2xl w-full max-w-5xl flex flex-col md:flex-row overflow-hidden transform transition-all h-full md:h-[75vh] md:max-h-[750px]",
                    },

                    // Close Button
                    h(
                        "button",
                        {
                            onClick: onClose,
                            className:
                                "absolute top-4 right-4 z-20 text-gray-400 hover:text-gray-900 bg-white/50 hover:bg-white rounded-full p-2 transition-colors inline-flex items-center justify-center md:text-gray-500",
                            "aria-label": "Schliessen",
                        },
                        h(
                            "svg",
                            {
                                className: "w-6 h-6",
                                fill: "none",
                                stroke: "currentColor",
                                viewBox: "0 0 24 24",
                            },
                            h("path", {
                                strokeLinecap: "round",
                                strokeLinejoin: "round",
                                strokeWidth: "2",
                                d: "M6 18L18 6M6 6l12 12",
                            }),
                        ),
                    ),

                    // Left Sidebar
                    leftSidebar,

                    // Right Sidebar
                    h(
                        "div",
                        {
                            className:
                                "w-full md:w-7/12 bg-white p-4 pt-6 md:p-10 overflow-y-auto relative flex flex-col",
                        },
                        step === 1
                            ? step1Content
                            : step === 2
                              ? step2Content
                              : step3Content,
                    ),
                ),
            );
        };

        let isModalOpen = false;
        let initialTopic = "health";
        let root = null;

        const renderModal = () => {
            const container = document.getElementById("german-modal-root");
            if (!container) return;

            if (!root) root = ReactDOM.createRoot(container);

            root.render(
                h(GermanConsultationModal, {
                    isOpen: isModalOpen,
                    initialTopic: initialTopic,
                    onClose: closeModal,
                }),
            );
        };

        const openModal = (e) => {
            let rawTopic = "health";
            if (e && e.detail && e.detail.topic) rawTopic = e.detail.topic;
            else if (typeof e === "string") rawTopic = e;

            const topicMap = {
                home: "health",
                health: "health",
                life: "wealth",
                wealth: "wealth",
                relocation: "other",
                liability: "other",
                family: "family",
                other: "other",
            };

            initialTopic = topicMap[rawTopic] || "health";
            isModalOpen = true;
            renderModal();
        };

        const closeModal = () => {
            isModalOpen = false;
            renderModal();
        };

        // Make functions global AND override legacy English modals
        window.openGermanModal = openModal;
        window.closeGermanModal = closeModal;

        // Legacy overrides
        window.openHealthModal = openModal;
        window.openContextualModal = openModal;
        window.openOffersModal = openModal;
        window.openConsultationModal = openModal;
        window.showConsultationModal = openModal;

        // Wire up 3rd Pillar queries to open with 'wealth' topic preset
        window.openLifePensionModal = () => openModal("wealth");
        window.openFinancialModal = () => openModal("wealth");

        // Re-render once on init state in case it missed early calls
        renderModal();

        // Listen for custom dispatch events
        window.addEventListener("openGermanModal", openModal);

        console.log("✅ German Consultation Modal Calendar-First loaded");
    });
</script>

<style>
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .modal-fadeIn {
        animation: fadeIn 0.4s ease-out forwards;
    }
</style>
