---
// Testimonials.astro
const testimonials = [
  {
    text: "After returning to Switzerland from abroad, Robert from Expat Savvy was a tremendous help consulting me about all the changes. He took the time to show me several options and definitely went the extra mile compared to other agents. That's why I'm giving 5 stars. Can only recommend!",
    author: "Steven",
    role: "Returning Resident"
  },
  {
    text: "Benjamin was super helpful with my supplementary insurance in Switzerland. He explained everything clearly, answered all my questions, and made the whole process easy. Really appreciated his professionalism and friendly attitude. Would definitely recommend him to anyone looking for insurance advice. Thanks again, Benjamin!",
    author: "Zachary",
    role: "New Expat in Zurich"
  },
  {
    text: "I was advised by Robert Kolar who gave me excellent advice regarding health insurance in Switzerland. As a citizen of the United States, the Swiss system of healthcare was very confusing and difficult for me to figure it out on my own. After the initial consultation, everything was much clearer and I was able to take steps in the right direction. I highly recommend Expat Savvy Consulting.",
    author: "Rina Hoshino",
    role: "American Expat"
  }
];
---

<div class="bg-white py-20 border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-red-500 font-bold text-sm tracking-widest uppercase mb-3">Real Reviews</p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-3">What Our Clients Say</h2>
      <p class="text-lg text-slate-500">Trusted by expats across Switzerland</p>
      <div class="mt-6">
        <a
          href="https://g.page/r/CYpve4Tr8JfoEBM/review"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg text-red-600 bg-red-50 hover:bg-red-100 border border-red-200 transition-all"
        >
          <svg class="h-4 w-4 mr-2" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.383 0 0 5.383 0 12s5.383 12 12 12 12-5.383 12-12S18.617 0 12 0zm0 4.92c1.658 0 3.152.674 4.285 1.808l-1.857 1.857C13.669 7.827 12.866 7.5 12 7.5c-2.485 0-4.5 2.015-4.5 4.5s2.015 4.5 4.5 4.5c2.153 0 3.978-1.527 4.402-3.537l1.098.998C16.93 15.831 14.702 17.5 12 17.5c-3.038 0-5.5-2.462-5.5-5.5s2.462-5.5 5.5-5.5z"/>
          </svg>
          Write a Review
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map(testimonial => (
        <div class="bg-slate-50 rounded-lg border border-slate-200 hover:border-red-300 hover:shadow-md transition-all p-7 relative flex flex-col">
          <div class="flex mb-4">
            {[...Array(5)].map(() => (
              <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">{testimonial.text}</p>
          <div class="flex items-center pt-4 border-t border-slate-200">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-red-50 text-red-500 font-bold text-sm">
              {testimonial.author.split(' ')[0][0]}
            </div>
            <div class="ml-3">
              <h3 class="font-semibold text-slate-900 text-sm whitespace-nowrap">{testimonial.author}</h3>
              <p class="text-xs text-slate-500">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
