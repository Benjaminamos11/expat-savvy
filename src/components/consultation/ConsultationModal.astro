---
// ConsultationModal.astro — Calendar-First 3-Step Flow
// Step 1: Topic + Timeline → Step 2: Pick date & time → Step 3: Form + Confirm booking
---

<!-- React Modal Container -->
<div id="english-modal-root"></div>

<!-- React loaded globally in BaseLayout -->
<script is:inline>
  // Immediately define placeholder functions that QUEUE calls until React loads.
  (function () {
    var pendingCalls = [];

    function queuedOpen(topic) {
      console.log("⏳ Modal still loading, queuing call with topic:", topic);
      pendingCalls.push(topic || "health");
    }

    window.openEnglishModal = queuedOpen;
    window.openHealthModal = queuedOpen;
    window.openContextualModal = queuedOpen;
    window.openOffersModal = queuedOpen;
    window.openConsultationModal = queuedOpen;
    window.showConsultationModal = queuedOpen;

    window.__consultationModalQueue = pendingCalls;
  })();
</script>

<script is:inline>
  function waitForReact(callback) {
    if (typeof React !== "undefined" && typeof ReactDOM !== "undefined") {
      callback();
    } else {
      setTimeout(function() { waitForReact(callback); }, 100);
    }
  }

  waitForReact(function() {
    var useState = React.useState;
    var useEffect = React.useEffect;
    var useCallback = React.useCallback;
    var useRef = React.useRef;
    var h = React.createElement;

    var CAL_API_BASE = "https://api.cal.com/v2";

    // ── Radio card ──
    var RadioCard = function(props) {
      return h(
        "label",
        {
          className:
            "flex items-center gap-3 p-3 md:p-4 rounded-xl border-2 cursor-pointer transition-all " +
            (props.checked
              ? "border-red-500 bg-red-50 shadow-sm"
              : props.emphasized
                ? "border-red-100 bg-white hover:border-red-200 hover:bg-gray-50"
                : "border-gray-200 bg-white hover:border-gray-300 hover:bg-gray-50"),
        },
        h("input", {
          type: "radio",
          name: "modal-intent",
          checked: props.checked,
          onChange: function() { props.onChange(props.value); },
          className: "sr-only",
        }),
        h(
          "span",
          {
            className:
              "w-5 h-5 flex-shrink-0 rounded-full border-2 flex items-center justify-center transition-colors " +
              (props.checked ? "bg-red-600 border-red-600" : "border-gray-300 bg-white"),
          },
          props.checked && h("div", { className: "w-2 h-2 rounded-full bg-white" })
        ),
        h("span", {
          className: "text-sm font-medium " + (props.checked ? "text-gray-900" : "text-gray-700"),
        }, props.label)
      );
    };

    // ── Timeline Pill ──
    var TimelinePill = function(props) {
      return h(
        "button",
        {
          type: "button",
          onClick: function() { props.onSelect(props.value); },
          className:
            "px-4 py-2.5 rounded-full text-sm font-medium transition-all border " +
            (props.selected
              ? "bg-slate-900 text-white border-slate-900 shadow-md"
              : "bg-white text-gray-600 border-gray-200 hover:border-gray-400 hover:bg-gray-50"),
        },
        props.label
      );
    };

    // ── Generate next business days ──
    function getBusinessDays(count) {
      var days = [];
      var today = new Date();
      for (var i = 0; days.length < count; i++) {
        var d = new Date(today);
        d.setDate(today.getDate() + i);
        if (d.getDay() !== 0) {
          days.push(d.toISOString().split("T")[0]);
        }
      }
      return days;
    }

    // ── Format time ──
    function formatTime(isoString, tz) {
      return new Date(isoString).toLocaleTimeString("en", {
        hour: "2-digit", minute: "2-digit", hour12: false, timeZone: tz,
      });
    }

    // ── Format date label ──
    function formatDateLabel(dateStr) {
      var d = new Date(dateStr + "T12:00:00");
      return d.toLocaleDateString("en", { weekday: "short", month: "short", day: "numeric" });
    }

    // ── Main Modal Component ──
    var ConsultationModal = function(props) {
      var isOpen = props.isOpen;
      var onClose = props.onClose;
      var initialTopic = props.initialTopic;

      var stepState = useState(1);
      var step = stepState[0];
      var setStep = stepState[1];

      var topicState = useState(initialTopic || "health");
      var mainTopic = topicState[0];
      var setMainTopic = topicState[1];

      var timelineState = useState("");
      var timeline = timelineState[0];
      var setTimeline = timelineState[1];

      var dateState = useState(null);
      var selectedDate = dateState[0];
      var setSelectedDate = dateState[1];

      var slotState = useState(null);
      var selectedSlot = slotState[0];
      var setSelectedSlot = slotState[1];

      var slotsState = useState([]);
      var slots = slotsState[0];
      var setSlots = slotsState[1];

      var loadingState = useState(false);
      var slotsLoading = loadingState[0];
      var setSlotsLoading = loadingState[1];

      var bookingState = useState(false);
      var bookingLoading = bookingState[0];
      var setBookingLoading = bookingState[1];

      var errorState = useState("");
      var errorMsg = errorState[0];
      var setErrorMsg = errorState[1];

      var doneState = useState(false);
      var bookingDone = doneState[0];
      var setBookingDone = doneState[1];

      var formState = useState({ name: "", email: "", phone: "", message: "" });
      var formData = formState[0];
      var setFormData = formState[1];

      var slotsCacheRef = useRef({});

      var detectedTZ = (typeof Intl !== "undefined" && Intl.DateTimeFormat)
        ? Intl.DateTimeFormat().resolvedOptions().timeZone || "Europe/Zurich"
        : "Europe/Zurich";

      var tzState = useState(detectedTZ);
      var timeZone = tzState[0];
      var setTimeZone = tzState[1];

      var tzOpenState = useState(false);
      var tzOpen = tzOpenState[0];
      var setTzOpen = tzOpenState[1];

      var commonTZList = ['Europe/Zurich','Europe/Berlin','Europe/Vienna','Europe/London','Europe/Paris','Europe/Amsterdam','Europe/Rome','Europe/Madrid','Europe/Stockholm','Europe/Warsaw','America/New_York','America/Chicago','America/Denver','America/Los_Angeles','America/Toronto','Asia/Dubai','Asia/Singapore','Asia/Tokyo','Asia/Hong_Kong','Australia/Sydney','Pacific/Auckland'];
      function shortTZName(tz) { return tz.replace(/_/g,' ').split('/').pop(); }

      var businessDays = getBusinessDays(7);

      var experts = {
        robert: {
          name: "Robert Kolar",
          title: "Senior Health Insurance Expert",
          subtitle: "Expat Specialist · DE/EN",
          valueProp: "Advice tailored for expats in English and German. Switzerland-based and independent.",
          badges: [
            "Independent comparison across Swiss insurers",
            "Expat specialist · Advisor in English/German",
            "Free and without obligation",
            "1000+ happy clients advised",
          ],
          image: "https://res.cloudinary.com/dphbnwjtx/image/upload/w_250,h_250,q_95,f_webp,c_fill,g_face,e_sharpen:100/v1757251477/Generated_Image_September_07_2025_-_9_20PM_uuse1r.webp",
          eventTypeId: 1894802,
          calApiKey: "cal_live_02d332e8841c6f13b371ee6dd3ca7ca8",
        },
        hans: {
          name: "Hans Steiner",
          title: "Certified Financial Planner IAF",
          subtitle: "Expat Specialist · DE/EN/FR",
          valueProp: "Independent advice for expats — free and without obligation.",
          badges: [
            "Independent comparison across Swiss insurers",
            "Expat specialist · Advisor in English/German/French",
            "Free and without obligation",
            "Switzerland-based company",
          ],
          image: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_auto,q_auto,w_250,h_250,c_fill,g_face/v1772294525/WhatsApp_Image_2026-02-28_at_10.33.38_pd2of6.jpg",
          eventTypeId: 4550098,
          calApiKey: "cal_live_8cb1d91e956c64fd591ca700ff9bc523",
        },
      };

      var activeExpert = mainTopic === "wealth" ? experts.hans : experts.robert;

      // Reset on open
      useEffect(function() {
        if (isOpen) {
          setStep(1);
          setMainTopic(initialTopic || "health");
          setTimeline("");
          setSelectedDate(null);
          setSelectedSlot(null);
          setSlots([]);
          setFormData({ name: "", email: "", phone: "", message: "" });
          setErrorMsg("");
          setBookingDone(false);
          document.body.style.overflow = "hidden";
        } else {
          document.body.style.overflow = "";
        }
        return function() { document.body.style.overflow = ""; };
      }, [isOpen, initialTopic]);

      // ESC key
      useEffect(function() {
        var handler = function(e) { if (e.key === "Escape" && isOpen) onClose(); };
        if (isOpen) document.addEventListener("keydown", handler);
        return function() { document.removeEventListener("keydown", handler); };
      }, [isOpen, onClose]);

      // Fetch slots when date changes
      useEffect(function() {
        if (!selectedDate || step !== 2) return;

        var cacheKey = activeExpert.eventTypeId + "-" + selectedDate + "-" + timeZone;
        var cached = slotsCacheRef.current[cacheKey];
        if (cached && Date.now() - cached.ts < 60000) {
          setSlots(cached.data);
          return;
        }

        setSlotsLoading(true);
        setSlots([]);

        var params = new URLSearchParams({
          eventTypeId: activeExpert.eventTypeId.toString(),
          startTime: selectedDate + "T00:00:00Z",
          endTime: selectedDate + "T23:59:59Z",
          timeZone: timeZone,
        });

        fetch(CAL_API_BASE + "/slots/available?" + params.toString(), {
          headers: {
            "Authorization": "Bearer " + activeExpert.calApiKey,
            "cal-api-version": "2024-08-13",
          },
        })
          .then(function(res) { return res.json(); })
          .then(function(json) {
            var s = (json.data && json.data.slots && json.data.slots[selectedDate]) || [];
            slotsCacheRef.current[cacheKey] = { data: s, ts: Date.now() };
            setSlots(s);
            setSlotsLoading(false);
          })
          .catch(function(err) {
            console.error("Slot fetch error:", err);
            setSlotsLoading(false);
          });
      }, [selectedDate, step, activeExpert.eventTypeId, timeZone]);

      if (!isOpen) return null;

      var handleInputChange = function(e) {
        var name = e.target.name;
        var value = e.target.value;
        setFormData(function(prev) {
          var next = {};
          for (var k in prev) next[k] = prev[k];
          next[name] = value;
          return next;
        });
      };

      // Book via Cal.com v2 API + lead capture
      var handleBooking = function() {
        if (!formData.name || !formData.email || !selectedSlot) return;

        setBookingLoading(true);
        setErrorMsg("");

        var calPayload = {
          eventTypeId: activeExpert.eventTypeId,
          start: selectedSlot,
          attendee: {
            name: formData.name,
            email: formData.email,
            timeZone: timeZone,
            language: "en",
          },
        };
        if (formData.phone || formData.message) {
          calPayload.metadata = {};
          if (formData.phone) calPayload.metadata.phone = formData.phone;
          if (formData.message) calPayload.metadata.notes = formData.message;
        }

        // Also capture lead
        var leadPayload = {
          name: formData.name,
          email: formData.email,
          phone: formData.phone,
          topic: "Consultation Strategy Session",
          language: "en",
          source: window.location.href,
          flow: "consultation_modal_calendar_first",
          url: window.location.href,
          device: window.innerWidth <= 768 ? "mobile" : "desktop",
          notes: {
            selected_topic: mainTopic,
            timeline: timeline,
            expert_assigned: activeExpert.name,
            message: formData.message,
            booked_slot: selectedSlot,
            booked_date: selectedDate,
          },
        };

        // Fire lead capture (don't block)
        fetch("/api/lead", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(leadPayload),
        }).catch(function(err) { console.error("Lead submission error:", err); });

        // Book via Cal.com v2 API
        fetch(CAL_API_BASE + "/bookings", {
          method: "POST",
          headers: {
            "Authorization": "Bearer " + activeExpert.calApiKey,
            "Content-Type": "application/json",
            "cal-api-version": "2024-08-13",
          },
          body: JSON.stringify(calPayload),
        })
          .then(function(res) {
            if (!res.ok) {
              return res.json().catch(function() { return {}; }).then(function(err) {
                throw new Error(err.message || "Booking failed (" + res.status + ")");
              });
            }
            return res.json();
          })
          .then(function() {
            setBookingDone(true);
            setBookingLoading(false);
            // Fire conversion events
            if (typeof window.fireBookingConversion === 'function') window.fireBookingConversion('consultation_modal');
            if (typeof window.fireFormSubmitConversion === 'function') window.fireFormSubmitConversion('consultation_booking', { expert: activeExpert.name, topic: mainTopic });
          })
          .catch(function(err) {
            console.error("Booking error:", err);
            setErrorMsg(err.message || "Booking failed. Please try again.");
            setBookingLoading(false);
          });
      };

      // ── Step dots ──
      var stepDots = h(
        "div",
        { className: "flex items-center justify-center gap-2 mb-6" },
        [1, 2, 3].map(function(s) {
          return h("div", {
            key: s,
            className:
              "h-1.5 rounded-full transition-all " +
              (s === step ? "w-8 bg-red-500" : s < step ? "w-4 bg-red-300" : "w-4 bg-gray-200"),
          });
        })
      );

      // ── Checkmark SVG ──
      var checkSvg = function() {
        return h("svg", { className: "w-5 h-5 text-green-400 mr-3 flex-shrink-0", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
          h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M5 13l4 4L19 7" })
        );
      };

      // ── LEFT SIDEBAR ──
      var leftSidebar = h(
        "div",
        { className: "!hidden md:!flex !w-full md:!w-5/12 bg-slate-900 text-white p-8 lg:p-10 flex-col relative overflow-y-auto !m-0 !p-8 lg:!p-10" },
        h("div", { className: "absolute inset-0 bg-gradient-to-b from-slate-800/50 to-slate-900/90 pointer-events-none" }),
        h("div", { className: "relative z-10 flex-1 flex flex-col" },
          h("span", { className: "text-red-500 font-semibold text-xs tracking-widest uppercase mb-8 block" }, "Your Consultant"),
          h("div", { className: "relative w-32 h-32 mb-6 shadow-xl" },
            h("img", { src: activeExpert.image, alt: activeExpert.name, className: "w-full h-full object-cover rounded-2xl border-2 border-slate-700 bg-slate-800" })
          ),
          h("h3", { className: "text-3xl font-extrabold mb-1" }, activeExpert.name),
          h("p", { className: "text-red-400 font-bold mb-1" }, activeExpert.title),
          h("p", { className: "text-slate-400 text-sm mb-6 pb-6 border-b border-slate-700" }, activeExpert.subtitle),
          h("p", { className: "text-lg text-slate-300 leading-relaxed font-light mb-8" }, '"' + activeExpert.valueProp + '"'),
          h("div", { className: "mt-auto" },
            h("ul", { className: "space-y-3" },
              activeExpert.badges.map(function(badge, idx) {
                return h("li", { key: idx, className: "flex items-center text-sm text-slate-300" }, checkSvg(), badge);
              })
            )
          )
        )
      );

      // ── STEP 1: Topic + Timeline ──
      var step1Content = h(
        "div",
        { className: "md:max-w-md mx-auto h-full flex flex-col md:justify-center modal-fadeIn py-1 md:py-2" },
        stepDots,
        h("div", { className: "mb-4 md:mb-6 text-center md:text-left !m-0 !p-0" },
          h("h2", { className: "text-2xl md:text-3xl font-extrabold text-gray-900 !mb-1 !mt-0 !font-sans !leading-tight" },
            "Book your free Swiss insurance consultation"
          ),
          h("p", { className: "text-gray-500 text-sm !m-0 !mt-2 !font-sans !leading-normal" },
            "Free online consultation for expats moving to or living in Switzerland. Independent advice in English or German."
          )
        ),
        h("div", { className: "mb-4 md:mb-6" },
          h("label", { className: "block text-sm font-semibold text-gray-700 mb-3" }, "What do you need help with most right now?"),
          h("div", { className: "space-y-2 md:space-y-3" },
            h(RadioCard, { label: "Health insurance", value: "health", checked: mainTopic === "health", onChange: setMainTopic, emphasized: true }),
            h(RadioCard, { label: "Tax optimization / Pillar 3a", value: "wealth", checked: mainTopic === "wealth", onChange: setMainTopic }),
            h(RadioCard, { label: "Other Swiss setup questions", value: "other", checked: mainTopic === "other", onChange: setMainTopic })
          )
        ),
        h("div", { className: "mb-4 md:mb-6" },
          h("label", { className: "block text-sm font-semibold text-gray-700 mb-3" }, "Where are you in your move to Switzerland?"),
          h("div", { className: "flex flex-wrap gap-2" },
            h(TimelinePill, { label: "Moving soon", value: "pre-move", selected: timeline === "pre-move", onSelect: setTimeline }),
            h(TimelinePill, { label: "Recently arrived", value: "under-3m", selected: timeline === "under-3m", onSelect: setTimeline }),
            h(TimelinePill, { label: "Already living in Switzerland", value: "over-3m", selected: timeline === "over-3m", onSelect: setTimeline })
          )
        ),
        h("button", {
          type: "button",
          disabled: !mainTopic || !timeline,
          onClick: function() { setStep(2); },
          className: "w-full flex items-center justify-center py-4 px-8 rounded-2xl shadow-lg text-lg font-bold text-white transition-all transform " +
            (mainTopic && timeline
              ? "bg-red-600 hover:bg-red-700 shadow-red-500/30 hover:-translate-y-0.5 cursor-pointer"
              : "bg-gray-300 cursor-not-allowed"),
        },
          "Continue",
          h("svg", { className: "ml-2 w-5 h-5", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
            h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M14 5l7 7m0 0l-7 7m7-7H3" })
          )
        )
      );

      // ── STEP 2: Pick date & time ──
      var step2Content = h(
        "div",
        { className: "md:max-w-md mx-auto h-full flex flex-col md:justify-center modal-fadeIn py-1 md:py-2" },
        stepDots,
        h("div", { className: "mb-4 md:mb-5" },
          h("button", {
            type: "button",
            onClick: function() { setStep(1); setSelectedDate(null); setSelectedSlot(null); setSlots([]); },
            className: "inline-flex items-center text-sm font-semibold text-gray-500 hover:text-gray-900 transition-colors mb-3",
          }, "← Back"),
          h("h2", { className: "text-2xl md:text-3xl font-extrabold text-gray-900 mb-1" }, "Pick a date & time"),
          h("p", { className: "text-gray-500 text-sm" }, "Choose when you'd like your free consultation with " + activeExpert.name + ".")
        ),

        // Date pills
        h("div", { className: "mb-4" },
          h("div", { className: "flex items-center justify-between mb-2" },
            h("label", { className: "text-xs font-semibold text-gray-500 uppercase tracking-wider" }, "Select a date"),
            h("div", { className: "flex items-center gap-1" },
              h("svg", { className: "w-3 h-3 text-gray-300", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
                h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" })
              ),
              !tzOpen
                ? h("span", {
                    className: "text-[10px] text-red-600 font-medium cursor-pointer hover:text-red-800 transition-colors",
                    onClick: function() { setTzOpen(true); }
                  }, shortTZName(timeZone) + " ▾")
                : h("select", {
                    className: "text-[10px] text-gray-500 bg-white border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:border-red-400",
                    value: timeZone,
                    autoFocus: true,
                    onChange: function(e) {
                      setTimeZone(e.target.value);
                      slotsCacheRef.current = {};
                      setTzOpen(false);
                    },
                    onBlur: function() { setTzOpen(false); }
                  }, (commonTZList.indexOf(timeZone) === -1 ? [timeZone] : []).concat(commonTZList).map(function(tz) {
                    return h("option", { key: tz, value: tz }, tz.replace(/_/g, " "));
                  }))
            )
          ),
          h("div", { className: "flex gap-2 overflow-x-auto pb-1", style: { scrollbarWidth: "none" } },
            businessDays.map(function(dateStr) {
              var d = new Date(dateStr + "T12:00:00");
              var dayName = d.toLocaleDateString("en", { weekday: "short" });
              var dayNum = d.getDate();
              var monthName = d.toLocaleDateString("en", { month: "short" });
              var isSelected = selectedDate === dateStr;
              return h("button", {
                key: dateStr,
                type: "button",
                onClick: function() { setSelectedDate(dateStr); setSelectedSlot(null); },
                className: "flex-shrink-0 px-3 py-2 text-center rounded-xl border-2 cursor-pointer transition-all " +
                  (isSelected
                    ? "border-red-500 bg-red-50 shadow-sm"
                    : "border-gray-200 bg-white hover:border-gray-300"),
              },
                h("div", { className: "text-[9px] uppercase text-gray-500 leading-none" }, dayName),
                h("div", { className: "text-lg font-bold leading-tight " + (isSelected ? "text-red-600" : "text-gray-900") }, dayNum),
                h("div", { className: "text-[9px] text-gray-400 leading-none" }, monthName)
              );
            })
          )
        ),

        // Time slots
        selectedDate && h("div", { className: "mb-4" },
          h("label", { className: "block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2" }, "Available times"),

          slotsLoading && h("div", { className: "flex items-center justify-center py-6" },
            h("div", { className: "w-5 h-5 border-2 border-red-200 border-t-red-600 rounded-full animate-spin mr-2" }),
            h("span", { className: "text-sm text-gray-500" }, "Loading times...")
          ),

          !slotsLoading && slots.length === 0 && h("p", { className: "text-sm text-gray-500 py-4 text-center" }, "No times available for this date. Try another day."),

          !slotsLoading && slots.length > 0 && h("div", { className: "grid grid-cols-3 sm:grid-cols-4 gap-2" },
            slots.map(function(slot) {
              var display = formatTime(slot.time, timeZone);
              var isSelected = selectedSlot === slot.time;
              return h("button", {
                key: slot.time,
                type: "button",
                onClick: function() { setSelectedSlot(slot.time); },
                className: "px-3 py-2.5 rounded-xl border-2 text-sm font-bold transition-all " +
                  (isSelected
                    ? "border-red-500 bg-red-50 text-red-600 shadow-sm"
                    : "border-gray-200 bg-white text-gray-700 hover:border-gray-300"),
              }, display);
            })
          )
        ),

        // Continue to form
        selectedSlot && h("button", {
          type: "button",
          onClick: function() { setStep(3); },
          className: "w-full flex items-center justify-center py-4 px-8 rounded-2xl shadow-lg text-lg font-bold text-white bg-red-600 hover:bg-red-700 shadow-red-500/30 hover:-translate-y-0.5 cursor-pointer transition-all transform mt-2",
        },
          "Continue",
          h("svg", { className: "ml-2 w-5 h-5", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
            h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M14 5l7 7m0 0l-7 7m7-7H3" })
          )
        ),

        // "Just message" escape
        h("div", { className: "text-center mt-4 pt-3 border-t border-gray-100" },
          h("button", {
            type: "button",
            onClick: function() { setStep(3); setSelectedSlot(null); setSelectedDate(null); },
            className: "text-xs text-gray-400 hover:text-gray-600 transition-colors underline",
          }, "Not ready to book? Just send us a message instead")
        )
      );

      // ── STEP 3: Form + Confirm (or message-only) ──
      var isMessageOnly = !selectedSlot;

      var step3Content = bookingDone
        // ── Success screen ──
        ? h("div", { className: "md:max-w-md mx-auto h-full flex flex-col items-center justify-center modal-fadeIn text-center py-8" },
            h("div", { className: "w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-4" },
              h("svg", { className: "w-8 h-8 text-green-500", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
                h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M5 13l4 4L19 7" })
              )
            ),
            h("h2", { className: "text-2xl font-extrabold text-gray-900 mb-2" }, isMessageOnly ? "Message Sent!" : "Booking Confirmed!"),
            h("p", { className: "text-gray-500 mb-2" },
              isMessageOnly
                ? "We'll get back to you shortly."
                : formatDateLabel(selectedDate) + " at " + formatTime(selectedSlot, timeZone)
            ),
            h("p", { className: "text-gray-500 text-sm mb-6" },
              isMessageOnly ? "" : "You'll receive a confirmation email at " + formData.email
            ),
            h("button", {
              type: "button",
              onClick: onClose,
              className: "px-8 py-3 bg-slate-900 text-white rounded-2xl font-bold hover:bg-slate-800 transition-colors",
            }, "Done")
          )
        // ── Form ──
        : h("div", { className: "md:max-w-md mx-auto h-full flex flex-col md:justify-center modal-fadeIn py-1 md:py-2" },
            stepDots,
            h("div", { className: "mb-4" },
              h("button", {
                type: "button",
                onClick: function() { setStep(2); setErrorMsg(""); },
                className: "inline-flex items-center text-sm font-semibold text-gray-500 hover:text-gray-900 transition-colors mb-3",
              }, "← Back"),
              h("h2", { className: "text-2xl md:text-3xl font-extrabold text-gray-900 mb-1" },
                isMessageOnly ? "Send us a message" : "Confirm your booking"
              ),
              !isMessageOnly && h("p", { className: "text-sm font-medium text-red-600" },
                formatDateLabel(selectedDate) + " at " + formatTime(selectedSlot, timeZone) + " · " + activeExpert.name
              )
            ),

            // Expert card (compact)
            !isMessageOnly && h("div", { className: "flex items-center gap-3 p-3 bg-gray-50 rounded-xl mb-4" },
              h("img", { src: activeExpert.image, alt: activeExpert.name, className: "w-10 h-10 rounded-full object-cover" }),
              h("div", {},
                h("p", { className: "text-sm font-bold text-gray-900" }, activeExpert.name),
                h("p", { className: "text-xs text-gray-500" }, activeExpert.title + " · up to 60 min")
              )
            ),

            // Form
            h("div", { className: "space-y-3 mb-4" },
              h("div", {},
                h("label", { htmlFor: "cm-name", className: "block text-sm font-semibold text-gray-700 mb-1" }, "Name *"),
                h("input", {
                  type: "text", id: "cm-name", name: "name", placeholder: "e.g. John",
                  value: formData.name, onChange: handleInputChange, required: true,
                  className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors",
                })
              ),
              h("div", {},
                h("label", { htmlFor: "cm-email", className: "block text-sm font-semibold text-gray-700 mb-1" }, "Email *"),
                h("input", {
                  type: "email", id: "cm-email", name: "email", placeholder: "john@example.com",
                  value: formData.email, onChange: handleInputChange, required: true,
                  className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors",
                })
              ),
              h("div", {},
                h("label", { htmlFor: "cm-phone", className: "block text-sm font-semibold text-gray-700 mb-1" }, "Phone (optional)"),
                h("input", {
                  type: "tel", id: "cm-phone", name: "phone", placeholder: "+41 79 123 45 67",
                  value: formData.phone, onChange: handleInputChange,
                  className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors",
                })
              ),
              h("div", {},
                h("label", { htmlFor: "cm-message", className: "block text-sm font-semibold text-gray-700 mb-1" },
                  isMessageOnly ? "Your message *" : "Anything we should know? (optional)"
                ),
                h("textarea", {
                  id: "cm-message", name: "message", rows: 2,
                  placeholder: isMessageOnly ? "What would you like help with?" : "e.g. I have a family of 4, I'm self-employed...",
                  value: formData.message, onChange: handleInputChange,
                  className: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 bg-white placeholder-gray-400 transition-colors resize-none",
                })
              )
            ),

            // Error message
            errorMsg && h("p", { className: "text-red-500 text-sm text-center mb-3" }, errorMsg),

            // Submit button
            h("button", {
              type: "button",
              disabled: !formData.name || !formData.email || bookingLoading || (isMessageOnly && !formData.message),
              onClick: function() {
                if (isMessageOnly) {
                  // Message-only: save to messages table
                  setBookingLoading(true);
                  fetch("/api/message", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                      name: formData.name,
                      email: formData.email,
                      phone: formData.phone,
                      message: formData.message,
                      source: window.location.href,
                      language: "en",
                      device: window.innerWidth <= 768 ? "mobile" : "desktop",
                    }),
                  })
                    .then(function() {
                      setBookingDone(true); setBookingLoading(false);
                      if (typeof window.fireFormSubmitConversion === 'function') window.fireFormSubmitConversion('consultation_message', { expert: activeExpert.name });
                    })
                    .catch(function(err) { setErrorMsg("Failed to send. Please try again."); setBookingLoading(false); });
                } else {
                  handleBooking();
                }
              },
              className: "w-full flex items-center justify-center py-4 px-8 rounded-2xl shadow-lg text-lg font-bold text-white transition-all transform " +
                (formData.name && formData.email && !bookingLoading
                  ? "bg-red-600 hover:bg-red-700 shadow-red-500/30 hover:-translate-y-0.5 cursor-pointer"
                  : "bg-gray-300 cursor-not-allowed"),
            },
              bookingLoading
                ? h("span", { className: "flex items-center gap-2" },
                    h("svg", { className: "animate-spin h-5 w-5 text-white", fill: "none", viewBox: "0 0 24 24" },
                      h("circle", { className: "opacity-25", cx: "12", cy: "12", r: "10", stroke: "currentColor", strokeWidth: "4" }),
                      h("path", { className: "opacity-75", fill: "currentColor", d: "M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" })
                    ),
                    isMessageOnly ? "Sending..." : "Booking..."
                  )
                : (isMessageOnly ? "Send Message" : "Confirm Booking")
            )
          );

      // ── RENDER ──
      return h(
        "div",
        { className: "fixed inset-0 z-50 flex items-end md:items-center justify-center p-0 md:p-6 font-sans antialiased text-gray-900 not-prose" },
        h("div", {
          className: "absolute inset-0 bg-gray-900/80 backdrop-blur-sm transition-opacity",
          onClick: onClose,
        }),
        h("div", {
          className: "relative bg-white rounded-t-3xl md:rounded-[2.5rem] shadow-2xl w-full max-w-5xl !flex !flex-col md:!flex-row overflow-hidden transform transition-all h-full md:h-[75vh] md:max-h-[750px]",
        },
          h("button", {
            onClick: onClose,
            className: "absolute top-4 right-4 z-20 text-gray-400 hover:text-gray-900 bg-white/50 hover:bg-white rounded-full p-2 transition-colors inline-flex items-center justify-center md:text-gray-500",
            "aria-label": "Close",
          },
            h("svg", { className: "w-6 h-6", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" },
              h("path", { strokeLinecap: "round", strokeLinejoin: "round", strokeWidth: "2", d: "M6 18L18 6M6 6l12 12" })
            )
          ),
          leftSidebar,
          h("div", { className: "!w-full md:!w-7/12 bg-white p-4 pt-6 md:p-10 overflow-y-auto relative !flex !flex-col" },
            step === 1 ? step1Content : step === 2 ? step2Content : step3Content
          )
        )
      );
    };

    // ── Mount ──
    var isModalOpen = false;
    var initialTopic = "health";
    var root = null;

    var renderModal = function() {
      var container = document.getElementById("english-modal-root");
      if (!container) return;
      if (!root) root = ReactDOM.createRoot(container);
      root.render(h(ConsultationModal, { isOpen: isModalOpen, initialTopic: initialTopic, onClose: closeModal }));
    };

    var openModal = function(e) {
      var rawTopic = "health";
      if (e && e.detail && e.detail.topic) rawTopic = e.detail.topic;
      else if (typeof e === "string") rawTopic = e;

      var topicMap = { home: "health", health: "health", life: "wealth", wealth: "wealth", relocation: "other", liability: "other", family: "health", other: "other" };
      initialTopic = topicMap[rawTopic] || "health";
      isModalOpen = true;
      renderModal();
    };

    var closeModal = function() {
      isModalOpen = false;
      renderModal();
    };

    // Global functions
    window.openEnglishModal = openModal;
    window.closeEnglishModal = closeModal;
    window.openHealthModal = openModal;
    window.openContextualModal = openModal;
    window.openOffersModal = openModal;
    window.openConsultationModal = openModal;
    window.showConsultationModal = openModal;
    window.openLifePensionModal = function() { openModal("wealth"); };
    window.openFinancialModal = function() { openModal("wealth"); };

    renderModal();

    // Replay queued calls
    if (window.__consultationModalQueue && window.__consultationModalQueue.length > 0) {
      var firstTopic = window.__consultationModalQueue[0];
      openModal(firstTopic);
      window.__consultationModalQueue.length = 0;
    }

    window.addEventListener("openEnglishModal", openModal);
    console.log("✅ Calendar-First Consultation Modal loaded");
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .modal-fadeIn {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
