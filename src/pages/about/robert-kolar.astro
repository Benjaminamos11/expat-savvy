---
import Layout from "../../layouts/Layout.astro";

const metadata = {
  title: "Robert Kolar - Health Insurance Expert | Expat Savvy",
  description: "Robert Kolar: Senior Health Insurance Expert at Expat Savvy. 15+ years helping expats navigate Swiss KVG/VVG health insurance. Free consultation.",
  canonical: "https://expat-savvy.ch/about/robert-kolar/",
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Robert Kolar",
  "jobTitle": "Health Insurance Expert",
  "description": "Senior Health Insurance Expert at Expat Savvy specializing in Swiss KVG mandatory and VVG supplementary insurance for expatriates",
  "image": "https://res.cloudinary.com/dphbnwjtx/image/upload/w_400,h_400,q_95,f_webp,c_fill,g_face/v1757251477/Generated_Image_September_07_2025_-_9_20PM_uuse1r.webp",
  "url": "https://expat-savvy.ch/about/robert-kolar/",
  "worksFor": {
    "@type": "Organization",
    "name": "Expat Savvy",
    "url": "https://expat-savvy.ch"
  },
  "knowsAbout": [
    "Swiss Health Insurance (KVG)",
    "Supplementary Insurance (VVG)",
    "Dental Insurance",
    "Private Hospital Insurance",
    "Insurance Provider Comparison",
    "New Arrivals Insurance Setup",
    "Insurance Switching",
    "Household & Liability Insurance"
  ],
  "sameAs": ["https://www.linkedin.com/in/robert-kolar-9bb889152/"],
  "affiliation": {
    "@type": "Organization",
    "name": "Expat Savvy",
    "url": "https://expat-savvy.ch"
  },
  "yearsOfExperience": 15
};

const specialties = [
  { title: "KVG Health Insurance", desc: "Mandatory basic insurance comparison across all Swiss providers — finding the best premium, deductible, and model for your situation." },
  { title: "VVG Supplementary Insurance", desc: "Hospital upgrades, dental, alternative medicine, international coverage — expert guidance on what's worth it." },
  { title: "Insurance Switching", desc: "Full switching support including premium comparison, cancellation letters, and new provider enrollment. Annual deadline: November 30." },
  { title: "New Arrivals Setup", desc: "Complete insurance setup for expats arriving in Switzerland. 90-day registration deadline guidance and provider selection." },
  { title: "Household & Liability", desc: "Hausratversicherung and Privathaftpflicht — essential coverage at the best rates." },
  { title: "Dental & Outpatient", desc: "Supplementary dental plans and outpatient coverage comparison across major Swiss insurers." },
];
---

<Layout title={metadata.title} description={metadata.description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <section class="bg-white pt-24 pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="w-full md:w-5/12">
          <div class="relative rounded-2xl overflow-hidden shadow-xl bg-gray-100 aspect-square max-w-[400px] mx-auto">
            <img
              src="https://res.cloudinary.com/dphbnwjtx/image/upload/w_400,h_400,q_95,f_webp,c_fill,g_face/v1757251477/Generated_Image_September_07_2025_-_9_20PM_uuse1r.webp"
              alt="Robert Kolar, Health Insurance Expert at Expat Savvy"
              class="w-full h-full object-cover"
              width="400"
              height="400"
            />
          </div>
        </div>
        <div class="w-full md:w-7/12 space-y-6">
          <span class="inline-block py-1 px-3 rounded-full bg-red-50 text-red-600 text-xs font-bold tracking-widest uppercase border border-red-100">Health Insurance Expert</span>
          <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900">Robert Kolar</h1>
          <p class="text-lg text-gray-600 leading-relaxed">
            Senior Health Insurance Expert at Expat Savvy with 15+ years of experience in the Swiss insurance market. Robert specializes in helping expats navigate the complexity of Swiss health insurance — from mandatory KVG to supplementary VVG coverage.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed">
            Whether you're new to Switzerland and need to set up insurance within the 90-day deadline, or you're looking to switch providers and save on premiums, Robert provides independent, unbiased advice tailored to your situation.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full">DE/EN</span>
            <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full">15+ years experience</span>
            <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full">Independent advisor</span>
          </div>
          <div class="flex gap-4 pt-2">
            <a href="/free-consultation/" class="inline-flex items-center px-6 py-3 bg-red-500 hover:bg-red-600 text-white font-semibold rounded-xl transition-colors shadow-lg">
              Book free consultation
            </a>
            <a href="https://www.linkedin.com/in/robert-kolar-9bb889152/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-5 py-3 border-2 border-gray-200 hover:border-gray-300 text-gray-700 font-medium rounded-xl transition-colors">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Specialties -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-gray-900 mb-10 text-center">Areas of Expertise</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {specialties.map(s => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <h3 class="text-lg font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-gray-600 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold mb-4">Get expert health insurance advice</h2>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Book a free consultation with Robert. He'll review your situation, compare options from 15+ Swiss insurers, and give you a clear recommendation.
      </p>
      <a href="/free-consultation/" class="inline-flex items-center px-8 py-4 text-lg font-semibold rounded-xl text-white bg-red-500 hover:bg-red-600 transition-colors shadow-lg">
        Schedule your free call
      </a>
    </div>
  </section>
</Layout>
