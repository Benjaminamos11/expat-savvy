---
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const providers = [
  {
    name: "Helsana",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1740406933/helsana-old8485.logowik.com_xc1tcn.webp",
    link: "/healthcare/all-insurances/helsana",
  },
  {
    name: "Swica",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1740406933/swica_logo_yvxvxr.png",
    link: "/healthcare/all-insurances/swica",
  },
  {
    name: "CSS",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1740414664/css-logo_yvxvxr.png",
    link: "/healthcare/all-insurances/css",
  },
  {
    name: "Sanitas",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1740406933/sanitas_logo_yvxvxr.png",
    link: "/healthcare/all-insurances/sanitas",
  },
  {
    name: "Concordia",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1760874780/concordia_logo_j8m2wl.webp",
    link: "/healthcare/all-insurances/concordia",
  },
  {
    name: "Assura",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1740406940/assura-logo-png_seeklogo-462524_zlvevx.png",
    link: "/healthcare/all-insurances/assura",
  },
  {
    name: "Groupe Mutuel",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1740508835/gm-logo_fznr7i.png",
    link: "/healthcare/all-insurances/groupe-mutuel",
  },
  {
    name: "Sympany",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_150/v1740508835/sympany-logo_fznr7i.png",
    link: "/healthcare/all-insurances/sympany",
  },
];

const hubCards = [
  {
    title: "Best Health Insurance 2026",
    description: "Side-by-side comparison of Switzerland's top 6 insurers for expats.",
    href: "/healthcare/best-health-insurance-switzerland/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  },
  {
    title: "Set Up Health Insurance",
    description: "New to Switzerland? Documents, deadlines, and step-by-step registration.",
    href: "/guides/how-to/set-up-health-insurance/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    title: "Choose Your Deductible",
    description: "Find your break-even point and decide between CHF 300 and CHF 2,500.",
    href: "/guides/how-to/choose-health-insurance-deductible/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    title: "Compare Insurance Models",
    description: "Standard vs HMO vs GP vs Telmed — which saves money without losing quality?",
    href: "/guides/how-to/change-insurance-models/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  },
  {
    title: "Switch Your Insurer",
    description: "Deadlines, cancellation letters, and a smooth handover checklist.",
    href: "/healthcare/switching-health-insurance/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>`,
  },
  {
    title: "Insurance by City",
    description: "Canton-specific premiums and recommendations for Zurich, Basel, Geneva, and more.",
    href: "/health-insurance/zurich/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    title: "Compare Providers Head-to-Head",
    description: "Swica vs Helsana, CSS vs Sanitas — pick any two and see how they stack up.",
    href: "/compare-providers/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="12" y1="4" x2="12" y2="20"/></svg>`,
  },
  {
    title: "Premium Subsidies",
    description: "Check your eligibility and learn how to apply for Pr\u00E4mienverbilligung.",
    href: "/guides/how-to/apply-premium-subsidies/",
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>`,
  },
];

const faqs = [
  {
    question: "Who must have health insurance in Switzerland?",
    answer: "Every person living in Switzerland — including expats, students, newborns, and most cross-border workers — must have basic health insurance (KVG/LAMal). You have 3 months from your arrival or registration date. Coverage is retroactive to day one."
  },
  {
    question: "What happens if I miss the 3-month registration deadline?",
    answer: "Your canton will assign you to an insurer, often at higher premiums. You may also face retroactive premium payments and penalties. Register as soon as possible after arriving to avoid unnecessary costs."
  },
  {
    question: "What is the difference between basic and supplementary insurance?",
    answer: "Basic insurance (KVG) is mandatory and covers doctor visits, hospital stays, medications, and maternity. Coverage is identical across all insurers — only premiums differ. Supplementary insurance (VVG) is optional and covers extras like dental, private rooms, and alternative medicine. Insurers can reject VVG applications."
  },
  {
    question: "How can I reduce my health insurance premiums?",
    answer: "Choose a higher deductible (up to CHF 2,500), select an alternative model (HMO, Telmed, or GP), exclude accident coverage if employed 8+ hours/week, and compare providers annually. Combining strategies can save 20-30% on premiums."
  },
  {
    question: "When is the deadline to switch health insurers?",
    answer: "For basic insurance, submit your cancellation letter by 30 November for coverage starting 1 January. Some insurers also allow a mid-year switch on 1 July with a 3-month notice period. Supplementary insurance deadlines vary by provider."
  },
];
---

<Layout
  title="Swiss Health Insurance for Expats | Complete Guide 2026"
  description="Everything expats need to know about Swiss health insurance — how it works, what it costs, how to choose, and when to switch. FINMA-certified guidance in English."
>
  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://expat-savvy.ch/"},
      {"@type": "ListItem", "position": 2, "name": "Health Insurance", "item": "https://expat-savvy.ch/health-insurance/"}
    ]
  }
  </script>

  <!-- FAQ JSON-LD -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': faqs.map((f) => ({
      '@type': 'Question',
      'name': f.question,
      'acceptedAnswer': { '@type': 'Answer', 'text': f.answer }
    }))
  })} />

  <!-- =============================== -->
  <!-- SECTION 1: HERO                 -->
  <!-- =============================== -->
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-gray-900 mb-6">
        Swiss Health Insurance for Expats
      </h1>
      <p class="text-xl text-gray-600 mb-10 leading-relaxed">
        Your complete guide to mandatory insurance, choosing the right plan, and saving money — written for English-speaking residents.
      </p>
      <button
        onclick="window.openHealthModal('home')"
        class="inline-flex items-center px-8 py-4 text-lg font-semibold rounded-xl text-white bg-red-600 hover:bg-red-700 transition-colors shadow-lg hover:shadow-xl"
      >
        Get Your Free Comparison
        <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </button>
      <p class="mt-4 text-gray-500">
        <a href="#explore" class="hover:text-gray-700 transition-colors">Or explore our guides below &darr;</a>
      </p>
    </div>
  </section>

  <!-- =============================== -->
  <!-- SECTION 2: HOW IT WORKS (brief) -->
  <!-- =============================== -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">How Swiss Health Insurance Works</h2>

      <div class="prose prose-lg text-gray-700">
        <p>
          Switzerland requires every resident to have basic health insurance (<strong>KVG/LAMal</strong>). The coverage is identical no matter which insurer you choose — what differs are premiums, customer service, and digital tools. You must register within <strong>3 months of arriving</strong> in Switzerland.
        </p>
        <p>
          Beyond the mandatory plan, you can add <strong>supplementary insurance (VVG)</strong> for extras like dental, private hospital rooms, or alternative medicine. Unlike basic insurance, supplementary plans vary between insurers and acceptance isn't guaranteed.
        </p>
        <p>
          New to Switzerland?
          <a href="/guides/how-to/set-up-health-insurance/" class="text-red-600 font-medium hover:underline">Read our step-by-step setup guide</a>. Interested in supplementary coverage?
          <a href="/private-health-insurance-switzerland/" class="text-red-600 font-medium hover:underline">See our private insurance overview</a>.
        </p>
      </div>

      <!-- Fix 6: prominent in-content link with keyword-rich anchor text -->
      <div class="mt-8 bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
        <p class="text-lg text-gray-800">
          Not sure which insurer to pick? See our
          <a href="/healthcare/best-health-insurance-switzerland/" class="text-red-600 font-semibold hover:underline">
            expert comparison of the best health insurers in Switzerland for 2026
          </a>
          — with side-by-side analysis of the top 6 providers and personalized recommendations.
        </p>
      </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- SECTION 3: EXPLORE BY TOPIC      -->
  <!-- =============================== -->
  <section id="explore" class="bg-white py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Explore by Topic</h2>
        <p class="text-lg text-gray-600">Find the right guide for your situation.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {hubCards.map((card) => (
          <a
            href={card.href}
            class="group bg-white border border-gray-200 rounded-xl p-6 hover:border-red-300 hover:shadow-md transition-all"
          >
            <div class="h-10 w-10 rounded-lg bg-red-50 text-red-600 flex items-center justify-center mb-4 group-hover:bg-red-100 transition-colors">
              <Fragment set:html={card.icon} />
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-red-600 transition-colors">{card.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{card.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- SECTION 4: QUICK COST OVERVIEW   -->
  <!-- =============================== -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Quick Cost Overview</h2>
      <p class="text-gray-600 mb-8">
        Health insurance premiums vary by canton, age, deductible, and model. Here are typical 2026 ranges:
      </p>

      <div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Category</th>
              <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Range (2026)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900">Adults (Zurich, standard model)</td>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">CHF 340 &ndash; 460 / month</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900">Children</td>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">CHF 100 &ndash; 150 / month</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900">Supplementary insurance</td>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">CHF 50 &ndash; 300+ / month</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="mt-6 text-center">
        <button
          onclick="window.openHealthModal('home')"
          class="inline-flex items-center px-6 py-3 text-sm font-semibold rounded-lg text-white bg-red-600 hover:bg-red-700 transition-colors shadow"
        >
          Get an exact quote for your canton
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- SECTION 5: BROWSE ALL INSURERS   -->
  <!-- =============================== -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Browse All Insurers</h2>
        <p class="text-gray-600">Click any provider to read our full review.</p>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8">
        {providers.map((p) => (
          <a
            href={p.link + "/"}
            class="flex flex-col items-center gap-2 group"
            title={p.name}
          >
            <div class="h-16 w-24 flex items-center justify-center grayscale group-hover:grayscale-0 opacity-70 group-hover:opacity-100 transition-all">
              <img
                src={p.logo}
                alt={p.name}
                class="max-h-12 w-auto"
                loading="lazy"
                width="120"
                height="48"
              />
            </div>
            <span class="text-xs text-gray-500 group-hover:text-red-600 transition-colors font-medium">{p.name}</span>
          </a>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href="/insurance-providers/" class="text-red-600 font-medium hover:underline text-sm">
          View all insurance providers &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- =============================== -->
  <!-- SECTION 6: FAQ                   -->
  <!-- =============================== -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>
      <dl class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white rounded-xl border border-gray-200 shadow-sm">
            <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-lg font-medium text-gray-900 list-none">
              {faq.question}
              <svg class="h-5 w-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <dd class="px-6 pb-5 text-gray-600 leading-relaxed">{faq.answer}</dd>
          </details>
        ))}
      </dl>
    </div>
  </section>

  <!-- =============================== -->
  <!-- SECTION 7: CTA FOOTER            -->
  <!-- =============================== -->
  <section class="bg-red-600 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">
        Need help choosing?
      </h2>
      <p class="text-xl text-red-100 mb-8">
        Get your free, independent comparison from our FINMA-certified team.
      </p>
      <button
        onclick="window.openHealthModal('home')"
        class="inline-flex items-center px-8 py-4 text-lg font-semibold rounded-xl text-red-600 bg-white hover:bg-red-50 transition-colors shadow-lg"
      >
        Book Free Consultation
      </button>
    </div>
  </section>
</Layout>
