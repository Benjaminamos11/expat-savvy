---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Prototype Startpage | Expat Savvy"
  description="Prototype booking interface for Swiss health insurance. Schedule free strategy sessions with FINMA-certified experts to optimize your coverage."
>
  <!-- Hero Section -->
  <section class="relative bg-slate-900 text-white min-h-[90vh] flex items-center pt-24 pb-12 overflow-hidden">
    <!-- Subtle background glows -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 pointer-events-none">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary-900/40 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-slate-800/60 rounded-full blur-[120px]"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10 max-w-7xl">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Column: Copy & Trust -->
        <div class="lg:col-span-6 lg:pr-8 space-y-8">
          <div class="inline-flex items-center space-x-2 bg-slate-800/50 rounded-full px-4 py-1.5 border border-slate-700/50">
            <svg class="w-4 h-4 text-primary-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            <span class="text-xs font-medium tracking-wide text-slate-300 uppercase">FINMA Registered Broker</span>
          </div>
          
          <h1 class="text-5xl lg:text-7xl font-bold leading-[1.1] tracking-tight">
            Schedule<br/>
            Your Free <span class="text-primary-500">15-Minute</span><br/>
            Strategy<br/>
            Session
          </h1>
          
          <p class="text-lg text-slate-300 max-w-xl leading-relaxed">
            Optimize your Swiss insurance portfolio with direct advice from registered experts. No costs, no obligations, just clarity.
          </p>
          
          <!-- Trust Cards -->
          <div class="space-y-4 max-w-md">
            <!-- Card 1 -->
            <div class="flex items-start p-5 rounded-2xl bg-slate-800/40 border border-slate-700/50 backdrop-blur-sm">
              <div class="bg-primary-500/10 p-2.5 rounded-lg mr-4 shrink-0 mt-1">
                <svg class="w-6 h-6 text-primary-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a2.12 2.12 0 1 0 3-3L15 9l-1-1 4-4a2.12 2.12 0 1 0-3-3l-4 4-1-1L5 8l2.5 2.5a2.12 2.12 0 1 0-3 3L7 16l-3 3a2.12 2.12 0 1 0 3 3l3-3"/><path d="m9 13.5 1.5 1.5"/><path d="m9 9 1.5 1.5"/><path d="m13.5 15 1.5 1.5"/><path d="m15 10.5 1.5 1.5"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1">100% Free Advisory</h3>
                <p class="text-sm text-slate-400">We are compensated by providers, ensuring our consultation remains free for you.</p>
              </div>
            </div>
            
            <!-- Card 2 -->
            <div class="flex items-start p-5 rounded-2xl bg-slate-800/40 border border-slate-700/50 backdrop-blur-sm">
              <div class="bg-primary-500/10 p-2.5 rounded-lg mr-4 shrink-0 mt-1">
                <svg class="w-6 h-6 text-primary-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1">No Obligation</h3>
                <p class="text-sm text-slate-400">Review your options with zero pressure to switch or sign anything today.</p>
              </div>
            </div>
          </div>
          
          <!-- Testimonial -->
          <div class="mt-8 pt-6 border-t border-slate-800">
            <div class="flex space-x-1 mb-2">
              <svg class="w-4 h-4 text-yellow-500 fill-yellow-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg class="w-4 h-4 text-yellow-500 fill-yellow-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg class="w-4 h-4 text-yellow-500 fill-yellow-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg class="w-4 h-4 text-yellow-500 fill-yellow-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg class="w-4 h-4 text-yellow-500 fill-yellow-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <p class="text-sm text-slate-300 italic mb-2">"The 15-minute call saved me over CHF 1,200 annually on my basic health insurance. Professional and very efficient."</p>
            <p class="text-xs font-semibold text-white">— Marc-Andre, Zürich</p>
          </div>
        </div>
        
        <!-- Right Column: Form Widget -->
        <div class="lg:col-span-6 relative">
          <div class="bg-white rounded-3xl shadow-2xl overflow-hidden text-slate-900 border border-slate-100">
            <!-- Form Header Progress -->
            <div class="px-8 pt-8 pb-4 border-b border-gray-100 flex items-center justify-between">
              <div class="flex flex-col items-center">
                <div class="w-8 h-8 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold text-sm mb-1 z-10">1</div>
                <span class="text-[10px] font-medium text-primary-600 uppercase tracking-wider">Topic</span>
              </div>
              <div class="h-px bg-gray-200 flex-grow mx-4 absolute left-12 right-12 top-[47px] z-0"></div>
              <div class="flex flex-col items-center relative z-10 bg-white px-2">
                <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-400 flex items-center justify-center font-bold text-sm mb-1 border border-slate-200">2</div>
                <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider">Time</span>
              </div>
              <div class="flex flex-col items-center relative z-10 bg-white px-2">
                <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-400 flex items-center justify-center font-bold text-sm mb-1 border border-slate-200">3</div>
                <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider">Details</span>
              </div>
              
              <div class="ml-4 text-right">
                <p class="text-[10px] text-slate-500 uppercase font-semibold">Availability</p>
                <p class="text-xs font-medium text-primary-600">Next available: <span class="font-bold">Today, 14:30</span></p>
              </div>
            </div>
            
            <div class="p-8">
              <!-- Step 1 Content -->
              <div class="mb-8">
                <h2 class="text-xl font-bold mb-4">1. Choose your consultation topic</h2>
                <div class="grid sm:grid-cols-2 gap-4">
                  <!-- Selected Card -->
                  <button class="text-left p-4 rounded-xl border-2 border-primary-500 bg-primary-50 relative transition-all block w-full">
                    <div class="absolute top-3 right-3 bg-primary-500 rounded-full w-5 h-5 flex items-center justify-center">
                      <svg class="w-3 h-3 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    </div>
                    <div class="bg-white w-10 h-10 rounded-lg flex items-center justify-center shadow-sm mb-3">
                      <svg class="w-5 h-5 text-primary-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                    </div>
                    <h3 class="font-semibold text-slate-900 mb-1">Health Insurance</h3>
                    <p class="text-xs text-slate-500 line-clamp-2">Lama, Grundversicherung & VVG optimization.</p>
                  </button>
                  
                  <!-- Unselected Card -->
                  <button class="text-left p-4 rounded-xl border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all block w-full">
                    <div class="bg-slate-100 w-10 h-10 rounded-lg flex items-center justify-center mb-3">
                      <svg class="w-5 h-5 text-slate-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                    </div>
                    <h3 class="font-semibold text-slate-900 mb-1">3rd Pillar / Tax</h3>
                    <p class="text-xs text-slate-500 line-clamp-2">Private pension planning and tax deduction strategies.</p>
                  </button>
                </div>
              </div>
              
              <!-- Step 2 Content (Preview) -->
              <div class="mb-8">
                <h2 class="text-xl font-bold mb-4">2. Select a preferred time</h2>
                
                <!-- Date Bar -->
                <div class="flex space-x-2 overflow-x-auto pb-2" style="scrollbar-width: none; -ms-overflow-style: none;">
                  <div class="flex flex-col items-center justify-center min-w-[60px] p-2 rounded-lg text-slate-400">
                    <span class="text-[10px] uppercase font-bold mb-1">Mon</span>
                    <span class="text-lg font-medium">24</span>
                  </div>
                  <div class="flex flex-col items-center justify-center min-w-[60px] p-2 rounded-lg text-slate-400">
                    <span class="text-[10px] uppercase font-bold mb-1">Tue</span>
                    <span class="text-lg font-medium">25</span>
                  </div>
                  <div class="flex flex-col items-center justify-center min-w-[60px] p-2 rounded-lg bg-slate-50 text-slate-900 font-bold border border-slate-200">
                    <span class="text-[10px] uppercase mb-1">Wed</span>
                    <span class="text-lg">26</span>
                  </div>
                  <div class="flex flex-col items-center justify-center min-w-[60px] p-2 rounded-lg bg-primary-600 text-white font-bold shadow-md">
                    <span class="text-[10px] uppercase mb-1">Thu</span>
                    <span class="text-lg">27</span>
                  </div>
                  <div class="flex flex-col items-center justify-center min-w-[60px] p-2 rounded-lg text-slate-400">
                    <span class="text-[10px] uppercase font-bold mb-1">Fri</span>
                    <span class="text-lg font-medium">28</span>
                  </div>
                   <div class="flex flex-col items-center justify-center min-w-[60px] p-2 rounded-lg text-slate-400 opacity-50">
                    <span class="text-[10px] uppercase font-bold mb-1">Sat</span>
                    <span class="text-lg font-medium">29</span>
                  </div>
                  <div class="flex flex-col items-center justify-center min-w-[60px] p-2 rounded-lg text-slate-400 opacity-50">
                    <span class="text-[10px] uppercase font-bold mb-1">Sun</span>
                    <span class="text-lg font-medium">30</span>
                  </div>
                </div>
                
                <!-- Time Slots -->
                <div class="flex flex-wrap gap-3 mt-4">
                  <button class="px-5 py-2 rounded-full border border-slate-200 text-sm font-medium text-slate-700 hover:border-slate-300 hover:bg-slate-50">09:30</button>
                  <button class="px-5 py-2 rounded-full border border-slate-200 text-sm font-medium text-slate-700 hover:border-slate-300 hover:bg-slate-50">10:30</button>
                  <button class="px-5 py-2 rounded-full border-2 border-primary-500 bg-primary-50 text-primary-700 text-sm font-bold shadow-sm">14:30</button>
                  <button class="px-5 py-2 rounded-full border border-slate-200 text-sm font-medium text-slate-700 hover:border-slate-300 hover:bg-slate-50">16:00</button>
                </div>
              </div>
              
              <!-- CTA Button -->
              <button class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-4 rounded-xl flex items-center justify-center transition-colors shadow-lg shadow-primary-500/30">
                Next: Enter Contact Details
                <svg class="w-5 h-5 ml-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </button>
              
              <p class="text-center text-[10px] text-slate-400 mt-4 leading-relaxed">
                By proceeding, you agree to our 100% free advisory policy. Your data is protected.
              </p>
            </div>
            
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Why Swiss Residents Choose Us</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Independent advice focused on value, <span class="font-bold">not</span> commission.</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow relative overflow-hidden group">
          <div class="w-12 h-12 bg-primary-50 text-primary-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">FINMA Certified</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            We are a registered broker under the Swiss Financial Market Supervisory Authority (FINMA), ensuring highest professional standards.
          </p>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-primary-500 to-primary-600 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
        </div>
        
        <!-- Feature 2 -->
        <div class="bg-slate-900 text-white p-8 rounded-2xl shadow-lg border border-slate-800 relative overflow-hidden group">
          <!-- Abstract bg graphic -->
          <div class="absolute -right-8 -bottom-8 opacity-10">
            <svg class="w-48 h-48" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <div class="w-12 h-12 bg-slate-800 text-primary-400 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3 relative z-10">Market Transparency</h3>
          <p class="text-slate-300 text-sm leading-relaxed relative z-10">
            Compare all major Swiss providers (Sanitas, CSS, Helsana, SWICA, etc.) in one single 15-minute call. No bias, just the best rates.
          </p>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-primary-400 to-primary-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
        </div>
        
        <!-- Feature 3 -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow relative overflow-hidden group">
          <div class="w-12 h-12 bg-primary-50 text-primary-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a2.12 2.12 0 1 0 3-3L15 9l-1-1 4-4a2.12 2.12 0 1 0-3-3l-4 4-1-1L5 8l2.5 2.5a2.12 2.12 0 1 0-3 3L7 16l-3 3a2.12 2.12 0 1 0 3 3l3-3"/><path d="m9 13.5 1.5 1.5"/><path d="m9 9 1.5 1.5"/><path d="m13.5 15 1.5 1.5"/><path d="m15 10.5 1.5 1.5"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Expert Strategy</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Our advisors specialize in both health and tax-advantaged savings (3a/3b), creating a holistic financial roadmap for you.
          </p>
          <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-primary-500 to-primary-600 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expert Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Image Side -->
        <div class="relative">
          <div class="rounded-3xl overflow-hidden shadow-2xl relative z-10 w-full max-w-md mx-auto aspect-[3/4]">
             <!-- Using a generic placeholder image of a professional -->
            <img 
              src="https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
              alt="Licensed Insurance Expert" 
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Decorative Background box -->
          <div class="absolute top-8 -bottom-8 -left-8 right-8 bg-slate-100 rounded-3xl z-0 max-w-md mx-auto hidden md:block"></div>
          
          <!-- Floating badge -->
          <div class="absolute -bottom-6 -right-6 md:right-0 lg:-right-12 bg-white p-5 rounded-2xl shadow-xl z-20 border border-slate-100 hidden sm:flex items-start max-w-xs">
            <div class="bg-primary-50 p-3 rounded-full mr-4 shrink-0">
              <svg class="w-6 h-6 text-primary-600 fill-primary-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 uppercase font-bold tracking-wider mb-1">Senior Advisor</p>
              <h4 class="font-bold text-slate-900 leading-tight">Robert Keller</h4>
              <p class="text-sm mt-3 text-slate-600 italic leading-relaxed">"My goal is to simplify the Swiss system for you. We find the gaps you didn't know existed."</p>
            </div>
          </div>
        </div>
        
        <!-- Text Side -->
        <div class="max-w-xl mx-auto md:mx-0">
          <h2 class="text-3xl lg:text-5xl font-bold text-slate-900 mb-6 leading-tight">Direct Access to Licensed Experts</h2>
          <p class="text-lg text-slate-600 mb-10 leading-relaxed">
            Skip the automated bots and generic call centers. Our strategy sessions are held with certified specialists who understand the nuances of Swiss cantonal differences.
          </p>
          
          <ul class="space-y-5 mb-10">
            <li class="flex items-start">
              <div class="bg-primary-50 p-1 rounded-full mr-4 mt-0.5">
                <svg class="w-4 h-4 text-primary-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-slate-700 font-medium">Cantonal Tax Optimization</span>
            </li>
            <li class="flex items-start">
              <div class="bg-primary-50 p-1 rounded-full mr-4 mt-0.5">
                <svg class="w-4 h-4 text-primary-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-slate-700 font-medium">VVG (Supplementary) Risk Assessment</span>
            </li>
            <li class="flex items-start">
              <div class="bg-primary-50 p-1 rounded-full mr-4 mt-0.5">
                <svg class="w-4 h-4 text-primary-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <span class="text-slate-700 font-medium">Inheritance & Pillar 3a Legal Advice</span>
            </li>
          </ul>
          
          <a href="/advisory" class="inline-flex items-center text-primary-600 font-semibold hover:text-primary-700 transition-colors group">
            Learn about our advisory process
            <svg class="w-5 h-5 ml-1 transform group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
