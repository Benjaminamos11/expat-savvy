---
import BaseLayout from '../layouts/BaseLayout.astro';
import SavvyAIChat from '../components/SavvyAIChat.astro';
export const prerender = false;
---
<BaseLayout title="Savvy AI" description="Chat with Savvy AI — your Swiss insurance expert. Compare premiums, get insurance checklists, and book free consultations.">
  <SavvyAIChat />
</BaseLayout>

<style is:global>
  /* Hide floating CTAs on chat page */
  #fcta-bar, #sticky-booking { display: none !important; }
  /* Chat fills available space — no footer scroll on this page */
  body { overflow: hidden; }
  main.flex-grow {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    flex: 1;
  }
  footer { display: none; }
</style>
