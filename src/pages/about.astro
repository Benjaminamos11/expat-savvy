---
import Layout from '../layouts/Layout.astro';
import ConsultationModal from '../components/consultation/ConsultationModal.astro';

const stats = [
  { number: "1,000+", label: "Expats Helped" },
  { number: "11+", label: "Years Experience" },
  { number: "100%", label: "Independent" },
  { number: "3", label: "Languages" }
];

const teamMembers = [
  {
    name: "Robert Kolar",
    role: "Health Insurance Expert",
    description: "Robert specializes in making Swiss health insurance understandable. He guides expats through every step — from choosing the right provider to optimizing coverage.",
    image: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,e_sharpen:60,w_400,a_hflip/v1774375416/Generated_Image_March_24_2026_-_9_02PM_rbjaw1.jpg",
    linkedin: "https://www.linkedin.com/in/robert-kolar-9bb889152/"
  },
  {
    name: "Hans Steiner",
    role: "Life Insurance & Financial Planning",
    description: "Hans is a certified Financial Planner IAF specializing in life insurance, 3rd pillar, and pension planning for expats. He provides independent advice in English, German, and French.",
    image: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_400,h_400,c_fill,g_face/v1772294525/WhatsApp_Image_2026-02-28_at_10.33.38_pd2of6.jpg",
    linkedin: ""
  },
  {
    name: "Benjamin Amos Wagner",
    role: "Founder & Digital Strategy",
    description: "Benjamin founded Expat Savvy to bridge the gap between complex Swiss insurance systems and the international community. He drives the digital experience and partnerships.",
    image: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_webp,q_auto,w_400,e_improve,e_sharpen/v1746960732/profilebild2_tar0si_qp4ybc.webp",
    linkedin: "https://www.linkedin.com/in/benjamin-amos-wagner-5a7888a5/"
  }
];

const insurancePartners = [
  {
    name: "Lang Partner",
    logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/v1746957117/download_1_zvevoy.webp",
    url: "#",
    invert: true
  },
  {
    name: "SIP Medical Family Office",
    logo: "https://www.sip.ch/wp-content/uploads/2024/10/SIP_medical_family_office-white_600px.png",
    url: "https://www.sip.ch",
    invert: true
  }
];

const strategicPartners = [
  { name: "holistiq", logo: "https://www.holistiq.ch/wp-content/uploads/2023/11/holistiq_logo_rgb_blue-1.svg", url: "https://www.holistiq.ch" },
  { name: "OFFLIST", url: "https://www.offlist.ch", text: true },
  { name: "relofinder.ch", url: "https://relofinder.ch", text: true },
  { name: "expat-services.ch", url: "https://www.expat-services.ch", text: true },
  { name: "insurance-guide.ch", url: "https://www.insurance-guide.ch", text: true },
  { name: "Primai", logo: "https://cdn.prod.website-files.com/670399972bf5fa97ae3c3673/670d2f8db17cbef11aecb233_Untitled%20design%20(26)-p-500.png", url: "https://primai.ch" },
  { name: "KillBill", logo: "https://killbill.ch/footer_logo_sticker.webp", url: "https://killbill.ch" },
];

const relocationPartners = [
  { name: "Prime Relocation", logo: "https://cdn.prod.website-files.com/6718b88a9ad8ce0f3ec5e7a6/672df357ed71370900ec04cb_output-onlinepngtools-p-800.png", url: "https://primerelocation.ch", darken: true },
  { name: "Lifestyle Managers", logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/f_auto,q_auto,w_400/v1774170519/Logo-LSM-black_uojfuu.avif", url: "https://lifestylemanagers.ch" },
  { name: "Welcome Service", logo: "https://www.welcome-service.ch/wp-content/uploads/2016/01/logo_welcome_service.gif.gif", url: "https://www.welcome-service.ch" },
  { name: "ReloNest", logo: "https://static.wixstatic.com/media/ce89dd_216a795ccb9745079cd192d82bc2b121~mv2.png/v1/crop/x_0,y_0,w_2895,h_812/fill/w_580,h_163,al_c,q_85,usm_0.66_1.00_0.01,enc_auto/Logo%20ReloNest%20v1.png", url: "https://www.relonest.com" },
  { name: "Lodge Relocation", logo: "https://www.lodge-relocation.com/wp-content/uploads/2025/10/Logo-Lodge-relocation-1-1-150x150.png", url: "https://www.lodge-relocation.com" },
  { name: "JustRelocated", logo: "https://img1.wsimg.com/isteam/ip/c24fc830-fa4d-4aa5-998f-dd9c3bb449a4/web%20site%20ia%CC%81in%20yatay.png/:/rs=w:987,h:150,cg:true,m/cr=w:987,h:150/qt=q:95", url: "#" },
];

const techPartners = [
  { name: "OpenHermit", logo: "https://res.cloudinary.com/dphbnwjtx/image/upload/e_background_removal/f_auto,q_auto/v1772955454/IMG_0667_mcncry.png", url: "https://openhermit.com", desc: "AI Agent Ready" },
  { name: "0gravity.ch", url: "https://0gravity.ch", text: true, desc: "Development & Technology" },
];
---

<Layout
  title="About Expat Savvy | Swiss Insurance Experts"
  canonicalURLProp="https://expat-savvy.ch/about/"
>
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Expat Savvy",
      "description": "Expert insurance guidance for expats in Switzerland",
      "url": "https://expat-savvy.ch",
      "logo": "https://res.cloudinary.com/dphbnwjtx/image/upload/v1740080077/logoexpatsavvy_sykutm.svg",
      "foundingDate": "2017",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Talacker 41",
        "addressLocality": "Zürich",
        "postalCode": "8001",
        "addressCountry": "CH"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+41763648888",
        "contactType": "customer service",
        "availableLanguage": ["English", "German", "French"]
      },
      "sameAs": [
        "https://www.linkedin.com/company/expat-savvy"
      ],
      "employee": [
        {
          "@type": "Person",
          "name": "Robert Kolar",
          "jobTitle": "Health Insurance Expert",
          "sameAs": "https://www.linkedin.com/in/robert-kolar-9bb889152/"
        },
        {
          "@type": "Person",
          "name": "Hans Steiner",
          "jobTitle": "Life Insurance & Financial Planning"
        },
        {
          "@type": "Person",
          "name": "Benjamin Amos Wagner",
          "jobTitle": "Founder & Digital Strategy",
          "sameAs": "https://www.linkedin.com/in/benjamin-amos-wagner-5a7888a5/"
        }
      ]
    }
  </script>

  <!-- Hero -->
  <div class="bg-white py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-red-500 font-bold text-sm tracking-widest uppercase mb-4">About Us</p>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-5">
        Insurance Guidance That's Actually <span class="text-red-400">Savvy</span>.
      </h1>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto mb-12">
        Independent advice for expats in Switzerland. No jargon, no bias — just clear answers.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-black text-slate-900">{stat.number}</div>
            <div class="w-8 h-0.5 bg-red-500 mx-auto mt-2 mb-2"></div>
            <div class="text-sm text-slate-500 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Who We Are -->
  <div class="bg-slate-50 py-16 md:py-20 border-t border-slate-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-slate-900 mb-6 text-center">Who We Are</h2>
      <div class="space-y-5 text-slate-600 text-lg leading-relaxed">
        <p>
          Expat Savvy is an independent insurance brokerage based in Zürich, built specifically for the international community in Switzerland. We're not tied to any insurer — our only commitment is to you.
        </p>
        <p>
          Swiss insurance is complex. Between mandatory health coverage, supplementary plans, pension pillars, and life insurance, it's easy to feel lost. We cut through the noise and give you clear, honest recommendations based on your actual situation.
        </p>
        <p>
          Whether you just arrived or you've been here for years, we help you find the right coverage at the right price — and we handle the paperwork so you don't have to.
        </p>
      </div>
    </div>
  </div>

  <!-- Team -->
  <div class="bg-white py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-red-500 font-bold text-sm tracking-widest uppercase mb-3">Our Team</p>
        <h2 class="text-3xl font-bold text-slate-900">The People Behind Expat Savvy</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {teamMembers.map(member => (
          <div class="bg-slate-50 rounded-lg border border-slate-200 p-8 text-center">
            <img
              src={member.image}
              alt={member.name}
              class="w-28 h-28 rounded-lg object-cover mx-auto mb-5"
              width="112"
              height="112"
              loading="lazy"
              decoding="async"
            />
            <h3 class="text-xl font-bold text-slate-900 mb-1">{member.name}</h3>
            <p class="text-red-500 font-medium text-sm mb-4">{member.role}</p>
            <p class="text-slate-600 text-sm leading-relaxed mb-6">{member.description}</p>
            {member.linkedin && (
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-red-500 transition-colors"
              >
                <svg class="h-4 w-4 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
                LinkedIn
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Partners -->
  <div class="bg-slate-50 py-16 md:py-20 border-t border-slate-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-red-500 font-bold text-sm tracking-widest uppercase mb-3">Network</p>
        <h2 class="text-3xl font-bold text-slate-900 mb-3">Trusted by Leading Partners</h2>
        <p class="text-slate-500 max-w-xl mx-auto">We work with trusted partners in relocation, insurance, and financial services.</p>
      </div>

      <!-- Strategic Partners -->
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Strategic Partners</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mb-10">
        {strategicPartners.map(partner => (
          <a href={partner.url} target="_blank" rel="noopener noreferrer" class="bg-white rounded-lg border border-slate-200 hover:border-red-300 transition-all p-5 flex items-center justify-center h-20">
            {partner.text ? (
              <span class="text-sm font-bold text-slate-700 tracking-tight">{partner.name}</span>
            ) : (
              <img src={partner.logo} alt={partner.name} class="h-8 object-contain max-w-[140px]" width="140" height="32" loading="lazy" />
            )}
          </a>
        ))}
      </div>

      <!-- Insurance Partners -->
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Insurance & Financial</h3>
      <div class="grid grid-cols-2 gap-3 mb-10">
        {insurancePartners.map(partner => (
          <a href={partner.url} target="_blank" rel="noopener noreferrer" class="bg-white rounded-lg border border-slate-200 hover:border-red-300 transition-all p-5 flex items-center justify-center h-20">
            <img src={partner.logo} alt={partner.name} class={`h-8 object-contain max-w-[140px] ${partner.invert ? 'invert' : ''}`} width="140" height="32" loading="lazy" />
          </a>
        ))}
      </div>

      <!-- Relocation Partners -->
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Relocation Network</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 gap-3 mb-10">
        {relocationPartners.map(partner => (
          <a href={partner.url} target="_blank" rel="noopener noreferrer" class="bg-white rounded-lg border border-slate-200 hover:border-red-300 transition-all p-5 flex items-center justify-center h-20">
            <img src={partner.logo} alt={partner.name} class={`h-8 object-contain max-w-[140px] ${partner.darken ? 'brightness-[0.3]' : ''}`} width="140" height="32" loading="lazy" />
          </a>
        ))}
      </div>

      <!-- Technology -->
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Technology & Innovation</h3>
      <div class="grid grid-cols-2 gap-3 mb-6">
        {techPartners.map(partner => (
          <a href={partner.url} target="_blank" rel="noopener noreferrer" class="bg-white rounded-lg border border-slate-200 hover:border-red-300 transition-all p-5 flex flex-col items-center justify-center h-20">
            {partner.text ? (
              <span class="text-sm font-bold text-slate-700 tracking-tight">{partner.name}</span>
            ) : (
              <img src={partner.logo} alt={partner.name} class="h-8 object-contain max-w-[100px]" width="100" height="32" loading="lazy" />
            )}
            <span class="text-[10px] text-slate-400 mt-1">{partner.desc}</span>
          </a>
        ))}
      </div>

      <div class="text-center mt-8">
        <a
          href="mailto:hello@expat-savvy.ch?subject=Partnership Inquiry"
          class="text-sm font-medium text-slate-500 hover:text-red-500 transition-colors"
        >
          Interested in partnering? Get in touch →
        </a>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-white py-16 md:py-20 border-t border-slate-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">
        Ready to Make the <span class="text-red-400">Savvy</span> Choice?
      </h2>
      <p class="text-lg text-slate-500 mb-8">
        Book a free consultation and get clear, independent advice tailored to your situation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button
          onclick="window.openHealthModal('home')"
          class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold rounded-xl text-white bg-red-500 hover:bg-red-600 shadow-lg shadow-red-200 transition-all"
        >
          Book Free Consultation
        </button>
        <a
          href="https://wa.me/41763648888"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold rounded-lg text-slate-700 bg-slate-100 hover:bg-slate-200 transition-all"
        >
          <svg class="h-5 w-5 mr-2 text-green-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>

</Layout>
