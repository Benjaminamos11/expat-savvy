# Cal.com Headless Integration (Hero Booking Widget)
# --------------------------------------------------
# Get your API Key from: https://cal.com/settings/developer/api-keys
CALCOM_API_KEY=your_calcom_api_key_here

# Event Type IDs (Found in your Cal.com Dashboard under each Event Type)
CALCOM_EVENT_TYPE_HEALTH=123456
CALCOM_EVENT_TYPE_TAX=234567
CALCOM_EVENT_TYPE_HOUSEHOLD=345678
CALCOM_EVENT_TYPE_GENERAL=456789

# Public Links (Fallback)
CAL_LINK_HEALTH=robertkolar/setting-up-health-insurance-in-switzerland
CAL_LINK_TAX=robertkolar/third-pillar-pension-solutions
CAL_LINK_HOUSEHOLD=robertkolar/household-liability-insurance
CAL_LINK_GENERAL=robertkolar/expat-savvy
